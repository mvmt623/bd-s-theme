<script>
(function () {
  var video    = document.getElementById('bd-mascot-video');
  var wrap     = video ? video.closest('.bd-mascot-wrap') : null;
  var soundBtn = document.getElementById('bd-sound-btn');
  var iconOn   = document.getElementById('bd-icon-sound');
  var iconOff  = document.getElementById('bd-icon-muted');
  var hint     = document.getElementById('bd-audio-hint');
  if (!video || !wrap) return;

  var audioUnlocked = false;
  var videoInView   = false;

  function unlockAudio() {
    if (audioUnlocked) return;
    audioUnlocked = true;
    if (hint) hint.style.opacity = '0';
    if (videoInView && !video.paused && video.muted) {
      video.muted = false;
      iconOn.style.display  = 'block';
      iconOff.style.display = 'none';
    }
  }
  ['click', 'touchstart', 'keydown'].forEach(function(evt) {
    document.addEventListener(evt, unlockAudio, { once: true, capture: true });
  });

  soundBtn.addEventListener('click', function() {
    video.muted = !video.muted;
    iconOn.style.display  = video.muted ? 'none'  : 'block';
    iconOff.style.display = video.muted ? 'block' : 'none';
  });

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        videoInView = true;
        wrap.classList.add('bd-visible');
        video.muted = !audioUnlocked;
        video.play().then(function() {
          soundBtn.classList.add('visible');
          iconOn.style.display  = video.muted ? 'none'  : 'block';
          iconOff.style.display = video.muted ? 'block' : 'none';
          if (video.muted && hint) hint.style.opacity = '1';
        }).catch(function() {});
      } else {
        videoInView = false;
        video.pause();
        video.currentTime = 0;
        video.muted = false;
        wrap.classList.remove('bd-visible');
        soundBtn.classList.remove('visible');
        if (hint) hint.style.opacity = '0';
        iconOn.style.display  = 'block';
        iconOff.style.display = 'none';
      }
    });
  }, { threshold: 0.15 });

  observer.observe(wrap);
  video.addEventListener('ended', function() { video.pause(); });
})();
</script>

