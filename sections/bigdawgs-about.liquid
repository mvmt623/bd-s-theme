{% comment %}
  BIG DAWGS - About Page Section
  Dark-branded full-page section matching homepage aesthetic
{% endcomment %}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }
  * { box-sizing: border-box; }

  /* ── ABOUT HERO ── */
  .bd-about-hero {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0000 50%, #0a0a0a 100%);
    color: var(--bd-white);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .bd-about-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(204,0,0,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .bd-about-hero-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .bd-about-badge {
    display: inline-block;
    background: var(--bd-red);
    color: var(--bd-white);
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: .3rem .85rem;
    border-radius: 3px;
    margin-bottom: 1.2rem;
  }
  .bd-about-hero h1 {
    color: var(--bd-white);
    font-size: 2.8rem;
    font-weight: 900;
    line-height: 1.15;
    margin: 0 0 1.2rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .bd-about-hero h1 span { color: var(--bd-red); }
  .bd-about-hero p {
    color: #bbb;
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .bd-about-divider {
    width: 60px;
    height: 3px;
    background: var(--bd-red);
    margin: 0 auto;
    border-radius: 2px;
  }

  /* ── STORY SECTION ── */
  .bd-story {
    background: var(--bd-dark);
    padding: 4.5rem 1.5rem;
  }
  .bd-story-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .bd-story-text h2 {
    color: var(--bd-white);
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 .5rem;
  }
  .bd-story-text h2 span { color: var(--bd-red); }
  .bd-story-text .bd-eyebrow {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bd-gold);
    margin-bottom: .6rem;
    display: block;
  }
  .bd-story-text p {
    color: #aaa;
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.2rem;
  }
  .bd-story-text p strong { color: var(--bd-white); }
  .bd-story-visual {
    background: var(--bd-gray);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
    border: 1px solid #444;
    position: relative;
    overflow: hidden;
  }
  .bd-story-visual::before {
    content: "";
    position: absolute;
    top: -30px; right: -30px;
    width: 120px; height: 120px;
    background: var(--bd-red);
    opacity: .1;
    border-radius: 50%;
  }
  .bd-story-logo-text {
    font-size: 3rem;
    font-weight: 900;
    color: var(--bd-white);
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: .5rem;
  }
  .bd-story-logo-text span { color: var(--bd-red); }
  .bd-story-logo-sub {
    color: var(--bd-gold);
    font-size: .8rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .bd-stat-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .bd-stat { text-align: center; }
  .bd-stat-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--bd-red);
    line-height: 1;
  }
  .bd-stat-label {
    font-size: .7rem;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: .2rem;
  }

  /* ── PRODUCTS SECTION ── */
  .bd-products-section {
    background: var(--bd-black);
    padding: 4.5rem 1.5rem;
  }
  .bd-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .bd-section-header .bd-eyebrow {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bd-gold);
    margin-bottom: .5rem;
    display: block;
  }
  .bd-section-header h2 {
    color: var(--bd-white);
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 .5rem;
  }
  .bd-section-header h2 span { color: var(--bd-red); }
  .bd-section-header p {
    color: #888;
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }
  .bd-products-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .bd-product-card {
    background: var(--bd-dark);
    border: 1px solid #2a2a2a;
    border-radius: 10px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color .25s, transform .25s;
  }
  .bd-product-card:hover {
    border-color: var(--bd-red);
    transform: translateY(-4px);
  }
  .bd-product-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .bd-product-card h3 {
    color: var(--bd-white);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 .5rem;
  }
  .bd-product-card p {
    color: #888;
    font-size: .9rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ── PRODUCT CTA LINKS ── */
  .bd-product-link {
    display: inline-block;
    margin-top: .75rem;
    color: var(--bd-red);
    font-size: .85rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .bd-product-link:hover { color: var(--bd-red-dark); }
  .bd-about-proof {
    display: inline-block;
    background: var(--bd-gold);
    color: #111;
    font-size: .82rem;
    font-weight: 800;
    padding: .3rem 1.1rem;
    border-radius: 20px;
    letter-spacing: .3px;
    margin: .5rem auto 1.5rem;
  }

  /* ── FINISHES SECTION ── */
  .bd-finishes-about {
    background: var(--bd-dark);
    padding: 4.5rem 1.5rem;
  }
  .bd-finishes-grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .bd-finish-card {
    background: #222;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
  }
  .bd-finish-card:hover { border-color: var(--bd-red); }
  .bd-finish-icon { font-size: 2rem; margin-bottom: 1rem; }
  .bd-finish-icon img { width: 100%; max-width: 220px; height: auto; border-radius: 8px; display: block; margin: 0 auto; }
  .bd-finish-video { width: 100%; max-width: 220px; aspect-ratio: 1/1; border-radius: 50%; overflow: hidden; margin: 0 auto; }
  .bd-finish-video video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bd-finish-card h3 {
    color: var(--bd-white);
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0 0 .75rem;
    letter-spacing: 1px;
  }
  .bd-finish-card p {
    color: #999;
    font-size: .85rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ── VALUES SECTION ── */
  .bd-values {
    background: var(--bd-black);
    padding: 4.5rem 1.5rem;
  }
  .bd-values-grid {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .bd-value-item .bd-value-icon {
    font-size: 2.2rem;
    margin-bottom: .8rem;
  }
  .bd-value-item h4 {
    color: var(--bd-white);
    font-size: .9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 .4rem;
  }
  .bd-value-item p {
    color: #777;
    font-size: .85rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA SECTION ── */
  .bd-about-cta {
    background: var(--bd-red);
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .bd-about-cta h2 {
    color: var(--bd-white);
    font-size: 2.2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 .75rem;
  }
  .bd-about-cta p {
    color: rgba(255,255,255,.8);
    font-size: 1.1rem;
    margin: 0 0 2rem;
  }
  .bd-cta-btn {
    display: inline-block;
    background: var(--bd-white);
    color: var(--bd-red);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: .9rem 2.5rem;
    border-radius: 5px;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }
  .bd-cta-btn:hover {
    background: var(--bd-light);
    transform: translateY(-2px);
  }
  .bd-cta-secondary {
    display: block;
    margin-top: 1rem;
    color: rgba(255,255,255,.7);
    font-size: .9rem;
    text-decoration: none;
  }
  .bd-cta-secondary:hover { color: var(--bd-white); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .bd-about-hero h1 { font-size: 2rem; }
    .bd-story-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .bd-products-grid { grid-template-columns: 1fr; }
    .bd-finishes-grid { grid-template-columns: 1fr; }
    .bd-values-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .bd-values-grid { grid-template-columns: 1fr; }
  }
</style>

{% render 'finish-effects' %}

<!-- HERO -->
<section class="bd-about-hero">
  <div class="bd-about-hero-inner">
    <span class="bd-about-badge">Our Story</span>
    <h1>Built by a <span>Collector</span>.<br>Made for the Hobby.</h1>
    <p>Big Dawgs was born from a simple frustration — premium cards deserved premium branding. We turned that idea into the hobby's most trusted custom sticker service.</p>
    <div style="text-align:center;"><span class="bd-about-proof">⭐ 500+ Collectors Served &nbsp;·&nbsp; ★★★★★ Across All Orders &nbsp;·&nbsp; 100% Reprint Guarantee</span></div>
    <div class="bd-about-divider"></div>
  </div>
</section>

<!-- STORY -->
<section class="bd-story">
  <div class="bd-story-inner">
    <div class="bd-story-text">
      <span class="bd-eyebrow">Where It Started</span>
      <h2>From the <span>Collection</span> to the Community</h2>
      <!-- ✅ CHANGE 1: authentic first-show story -->
      <p>It started when I set up at my first card show. Looking at all of my cards stuffed in 5,000 Ct. boxes and displayed in cases — yet I was the only person there that knew my brand. No Logo. No branding. Just plastic casings.</p>
      <p><strong>Big Dawgs was built to fix that.</strong> We started making custom stickers for our own collection, then for friends, then for dealers, then for shops — and word spread fast. Collectors who care about the details found us.</p>
      <p>Today we serve <strong>500+ collectors and card shops</strong> across the country. Every sticker is made to spec, printed sharp, and shipped fast — because we know your collection doesn't wait.</p>
    </div>
    <div class="bd-story-visual">
      <div class="bd-story-logo-text">BIG<br><span>DAWGS</span></div>
      <div class="bd-story-logo-sub">Custom Card Stickers</div>
      <div class="bd-stat-row">
        <div class="bd-stat">
          <div class="bd-stat-num">500+</div>
          <div class="bd-stat-label">Happy Collectors</div>
        </div>
        <div class="bd-stat">
          <div class="bd-stat-num">3</div>
          <div class="bd-stat-label">Premium Finishes</div>
        </div>
        <!-- ✅ CHANGE 2: 24hr → 5–7 Days -->
        <div class="bd-stat">
          <div class="bd-stat-num">5–7</div>
          <div class="bd-stat-label">Day Turnaround</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRODUCTS -->
<section class="bd-products-section">
  <div class="bd-section-header">
    <span class="bd-eyebrow">What We Make</span>
    <h2>Everything Your <span>Collection</span> Needs</h2>
    <p>From one-touch stickers to card stands, we've got your branding covered.</p>
  </div>
  <div class="bd-products-grid">
    <!-- ✅ CHANGE 4: residue-free added + Small/Medium/Large -->
    <div class="bd-product-card">
      <div class="bd-product-icon">🏷️</div>
      <h3>Custom Card Stickers</h3>
      <p>One Touch and Toploader stickers in Matte, Holographic, and Cracked Ice finishes. Three sizes — Small, Medium, Large. <strong>100% residue-free</strong> — safe on all holders. Bulk pricing available.</p>
      <a href="/products/custom-card-stickers" class="bd-product-link">Order Yours →</a>
    </div>
    <div class="bd-product-card">
      <div class="bd-product-icon">📦</div>
      <h3>Sample Pack</h3>
      <p>Try every size and style before committing to bulk. Includes Mag stickers, Toploader stickers, and flat stickers in one pack. Perfect for first-timers.</p>
      <a href="/products/sample-pack" class="bd-product-link">Shop →</a>
    </div>
    <div class="bd-product-card">
      <div class="bd-product-icon">🃏</div>
      <h3>Flat Stickers</h3>
      <p>Custom die-cut stickers in 1"×1" through 5"×5" sizes. Great for raw cards, storage boxes, display cases, or anywhere you want your logo.</p>
      <a href="/collections/flat-stickers" class="bd-product-link">Shop →</a>
    </div>
    <div class="bd-product-card">
      <div class="bd-product-icon">🖼️</div>
      <h3>3D Printed Card Stands</h3>
      <p>Show off your best cards with custom-printed display stands. Add your logo, IG handle, QR code, or payment info. Logo-only or fully customized.</p>
      <a href="/products/3d-printed-card-stand" class="bd-product-link">Shop →</a>
    </div>
    <div class="bd-product-card">
      <div class="bd-product-icon">✨</div>
      <h3>Holographic Finish</h3>
      <p>Eye-catching rainbow holographic stickers that make your slabs pop at any show. The go-to finish for high-end collections and display setups.</p>
      <a href="/products/custom-card-stickers" class="bd-product-link">Shop →</a>
    </div>
    <div class="bd-product-card">
      <div class="bd-product-icon">❄️</div>
      <h3>Cracked Ice Finish</h3>
      <p>A unique fractured-ice pattern effect that catches the light differently from every angle. Exclusive to Big Dawgs — you won't find this anywhere else.</p>
      <a href="/products/custom-card-stickers" class="bd-product-link">Shop →</a>
    </div>
  </div>
</section>

<!-- FINISHES -->
<section class="bd-finishes-about">
  <div class="bd-section-header">
    <span class="bd-eyebrow">Our Finishes</span>
    <h2>Three <span>Finishes</span>, Zero Compromises</h2>
    <p>Every finish is custom-printed with your logo. Pick the look that matches your brand.</p>
  </div>
  <div class="bd-finishes-grid">
    <div class="bd-finish-card">
      <div class="bd-finish-icon"><img src="https://cdn.shopify.com/s/files/1/0738/3724/8706/files/bd-A.png?v=1773082307"></div>
      <h3><span class="bd-ftag bd-ftag--matte">Matte</span></h3>
      <p>Clean, professional, zero glare. Matte finish card holder stickers are the go-to for sellers who want a sharp, understated look. Perfect for brand-focused card shops and bulk orders.</p>
    </div>
    <div class="bd-finish-card">
      <div class="bd-finish-icon"><div class="bd-finish-video">
        <video autoplay loop muted playsinline>
          <source src="https://cdn.shopify.com/videos/c/o/v/5b66dc1e7bfe4005bb25ee02d6897e59.mp4" type="video/mp4">
        </video>
      </div></div>
      <h3><span class="bd-ftag bd-ftag--holo">Holographic</span></h3>
      <p>Full rainbow color-shifting effect. Holographic stickers turn heads at card shows, breaks, and on social. The most eye-catching option in the hobby.</p>
    </div>
    <div class="bd-finish-card">
      <div class="bd-finish-icon"><div class="bd-finish-video">
        <video autoplay loop muted playsinline>
          <source src="https://cdn.shopify.com/videos/c/o/v/ee4d3ff648bc45108d0349ccb2eadcae.mp4" type="video/mp4">
        </video>
      </div></div>
      <h3><span class="bd-ftag bd-ftag--ice"><span class="bd-ftag-text">Cracked Ice</span><svg class="bd-ftag-ice-svg" viewBox="0 0 100 28" preserveAspectRatio="none">{% render 'finish-ice-svg' %}</svg></span></h3>
      <p>A unique fractured, shattered-ice pattern distinct from standard holo. Instantly recognizable — a signature look that sets your brand apart.</p>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="bd-values">
  <div class="bd-section-header">
    <span class="bd-eyebrow">Why Big Dawgs</span>
    <h2>The <span>Standard</span> We Hold Ourselves To</h2>
  </div>
  <div class="bd-values-grid">
    <div class="bd-value-item">
      <div class="bd-value-icon">🎯</div>
      <h4>Collector-Built</h4>
      <p>We're collectors first. We know what matters and what doesn't.</p>
    </div>
    <!-- ✅ CHANGE 3: 24–48 hours → 5–7 business days -->
    <div class="bd-value-item">
      <div class="bd-value-icon">⚡</div>
      <h4>Fast Turnaround</h4>
      <p>Most orders ship within 5–7 business days of artwork approval.</p>
    </div>
    <div class="bd-value-item">
      <div class="bd-value-icon">💎</div>
      <h4>Premium Print</h4>
      <p>High-resolution output on professional-grade sticker stock only.</p>
    </div>
    <div class="bd-value-item">
      <div class="bd-value-icon">🤝</div>
      <h4>Real Support</h4>
      <p>Questions? We respond fast — because we actually care about your order.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bd-about-cta">
  <h2>Ready to Brand Your Cards?</h2>
  <p>Join 500+ collectors who've upgraded their setup with Big Dawgs stickers.</p>
  <a href="/products/custom-card-stickers" class="bd-cta-btn">Start Your Order →</a>
  <a href="/pages/faq" class="bd-cta-secondary">Have questions? Read our FAQ</a>
</section>

