{% comment %}
  BIG DAWGS — Collection Hero Section
  Renders ONLY on /collections/all via handle check.
  Injected into collection.json so it's safe on all other collection pages.
{% endcomment %}

{% if collection.handle == 'all' %}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-white: #FFFFFF;
  }

  /* ─── PAGE-WIDE DARK OVERRIDE ─── */
  body {
    background-color: #0f0f0f !important;
  }

  /* Hide the redundant generic "Products" heading section —
     our hero already serves as the page header */
  [id$="__section"] {
    display: none !important;
  }

  /* ── HERO ── */
  .bdc-hero {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0000 50%, #0a0a0a 100%);
    padding: 4.5rem 1.5rem 3.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .bdc-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(204,0,0,0.13) 0%, transparent 70%);
    pointer-events: none;
  }
  .bdc-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .bdc-badge {
    display: inline-block;
    background: var(--bd-red);
    color: #fff;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: .3rem .9rem;
    border-radius: 3px;
    margin-bottom: 1.1rem;
  }
  .bdc-hero h1 {
    color: #fff !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    display: block !important;
    font-size: 3.2rem;
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .bdc-hero h1 em {
    font-style: normal;
    color: var(--bd-red);
  }
  .bdc-hero-sub {
    color: #bbb;
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto 2rem;
    line-height: 1.75;
  }

  /* ── CATEGORY PILLS ── */
  .bdc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    justify-content: center;
  }
  .bdc-pill {
    display: inline-block;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    color: #bbb;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: .45rem 1.1rem;
    border-radius: 20px;
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
    transition: background .2s, border-color .2s, color .2s, transform .15s;
  }
  .bdc-pill:hover {
    background: rgba(204,0,0,.15);
    border-color: var(--bd-red);
    color: #fff;
    transform: translateY(-1px);
  }
  .bdc-pill--active {
    background: var(--bd-red) !important;
    border-color: var(--bd-red) !important;
    color: #fff !important;
  }

  /* ── TRUST BAR ── */
  .bdc-trust {
    background: #111111;
    border-bottom: 1px solid #1e1e1e;
    padding: .9rem 1.5rem;
  }
  .bdc-trust-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }
  .bdc-trust-item {
    display: flex;
    align-items: center;
    gap: .45rem;
    color: #777;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: .3rem 1.5rem;
  }
  .bdc-trust-icon { font-size: .95rem; line-height: 1; }
  .bdc-trust-sep {
    width: 1px;
    height: 14px;
    background: #2a2a2a;
    flex-shrink: 0;
  }

  /* ─── PRODUCT GRID DARK OVERRIDE ───
     Shopify dynamically prefixes section IDs with the template ID.
     Using [id$="__main"] and [id$="__section"] attribute selectors
     to match regardless of the template prefix. */

  /* Dark background for the main collection section */
  [id$="__main"],
  [id$="__main"] .section-background {
    background-color: #0f0f0f !important;
  }

  /* Center product grid items (when fewer items than columns) */
  [id$="__main"] .product-grid,
  [id$="__main"] ul.product-grid,
  [id$="__main"] [class*="product-grid"] {
    justify-content: center !important;
  }

  /* Product card dark treatment */
  [id$="__main"] product-card {
    background: #181818 !important;
    border-radius: 10px !important;
    overflow: hidden !important;
    transition: transform .25s ease, box-shadow .25s ease !important;
    display: block !important;
  }
  [id$="__main"] product-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 16px 40px rgba(0,0,0,.6) !important;
  }
  [id$="__main"] product-card .media img,
  [id$="__main"] product-card img {
    transition: transform .3s ease !important;
  }
  [id$="__main"] product-card:hover .media img,
  [id$="__main"] product-card:hover img {
    transform: scale(1.04) !important;
  }
  /* Product title */
  [id$="__main"] product-card .product-card-title,
  [id$="__main"] product-card [class*="title"],
  [id$="__main"] product-card h2,
  [id$="__main"] product-card h3,
  [id$="__main"] product-card .h6,
  [id$="__main"] product-card .rte {
    color: #eeeeee !important;
    background: transparent !important;
    background-color: transparent !important;
  }
  /* Price */
  [id$="__main"] product-card product-price,
  [id$="__main"] product-card [class*="price"],
  [id$="__main"] product-card .price {
    color: #aaa !important;
  }
  /* Card info area */
  [id$="__main"] product-card .product-card-info,
  [id$="__main"] product-card .card-info {
    padding: .75rem 1rem 1rem !important;
    background: #181818 !important;
  }
  /* Filter/sort bar */
  [id$="__main"] [class*="facet"],
  [id$="__main"] [class*="sort"] {
    color: #999 !important;
  }
  [id$="__main"] [class*="count"] {
    color: #666 !important;
  }

  /* ── "STARTING AT" PRICE PREFIX ──
     Adds a small label above each product card price
     so customers understand it's a base/minimum price */
  [id$="__main"] product-card product-price {
    display: block;
  }
  [id$="__main"] product-card product-price::before {
    content: "Starting at";
    display: block;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #555;
    margin-bottom: .1rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 750px) {
    .bdc-hero { padding: 3.5rem 1.2rem 3rem; }
    .bdc-hero h1 { font-size: 2.3rem !important; }
    .bdc-trust-sep { display: none; }
    .bdc-trust-item { padding: .3rem .8rem; }
  }
  @media (max-width: 480px) {
    .bdc-hero h1 { font-size: 2rem !important; }
    .bdc-pills { gap: .4rem; }
  }
</style>

<!-- HERO -->
<section class="bdc-hero">
  <div class="bdc-hero-inner">
    <span class="bdc-badge">The Full Lineup</span>
    <h1>Built For<br><em>Collectors</em>.</h1>
    <p class="bdc-hero-sub">Custom card stickers, holo finishes, sample packs, and more — every product made with the hobby in mind.</p>
    <div class="bdc-pills">
      <button class="bdc-pill bdc-pill--active" data-filter="">All Products</button>
      <button class="bdc-pill" data-filter="card sticker">Card Stickers</button>
      <button class="bdc-pill" data-filter="flat sticker">Flat Stickers</button>
      <button class="bdc-pill" data-filter="sample pack">Sample Packs</button>
      <button class="bdc-pill" data-filter="accessor">Accessories</button>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="bdc-trust">
  <div class="bdc-trust-inner">
    <div class="bdc-trust-item">
      <span class="bdc-trust-icon">⚡</span>
      <span>Ships in 5–7 Business Days</span>
    </div>
    <div class="bdc-trust-sep"></div>
    <div class="bdc-trust-item">
      <span class="bdc-trust-icon">🎨</span>
      <span>Collector-Grade Finishes</span>
    </div>
    <div class="bdc-trust-sep"></div>
    <div class="bdc-trust-item">
      <span class="bdc-trust-icon">📦</span>
      <span>Bulk Pricing Available</span>
    </div>
    <div class="bdc-trust-sep"></div>
    <div class="bdc-trust-item">
      <span class="bdc-trust-icon">🏆</span>
      <span>Designed by Hobbyists</span>
    </div>
  </div>
</div>

{% comment %}
  product.type is not set in this store's admin, so we derive the
  filter category from the product handle instead — which IS descriptive.
  Produces: { "custom-card-stickers": "card sticker", ... }
{% endcomment %}
<script>
window.__bdProductTypes = {
  {% for product in collection.products %}
  {% if product.handle contains 'card-sticker' %}{% assign bd_cat = 'card sticker' %}
  {% elsif product.handle contains 'flat-sticker' %}{% assign bd_cat = 'flat sticker' %}
  {% elsif product.handle contains 'sample' %}{% assign bd_cat = 'sample pack' %}
  {% else %}{% assign bd_cat = 'accessor' %}
  {% endif %}
  {{ product.handle | json }}: {{ bd_cat | json }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
};
</script>

<script>
(function () {
  'use strict';

  function onReady(fn) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fn);
    } else {
      fn();
    }
  }

  /* Extract product handle from a card's first /products/ link */
  function getHandle(card) {
    var link = card.querySelector('a[href*="/products/"]');
    if (!link) return null;
    var m = link.getAttribute('href').match(/\/products\/([^/?#]+)/);
    return m ? m[1] : null;
  }

  /* Get every product item wrapper in the grid */
  function getProductItems() {
    var main = document.querySelector('[id$="__main"]');
    if (!main) return [];
    /* Horizon theme: each product is an <li> inside .product-grid */
    var items = main.querySelectorAll('.product-grid > li, ul.product-grid > li');
    if (!items.length) {
      items = main.querySelectorAll('.product-grid > div');
    }
    if (!items.length) {
      /* Final fallback: product-card custom elements */
      items = main.querySelectorAll('product-card');
    }
    return Array.prototype.slice.call(items);
  }

  /* Show/hide items — keyword is a lowercase substring to match against mapped category */
  function filterProducts(keyword) {
    getProductItems().forEach(function (item) {
      if (!keyword) {
        item.style.display = '';
        return;
      }
      var handle = getHandle(item);
      if (!handle) { item.style.display = ''; return; }
      var cat = (window.__bdProductTypes && window.__bdProductTypes[handle]) || '';
      item.style.display = cat.indexOf(keyword) !== -1 ? '' : 'none';
    });
  }

  function initPills() {
    var pills = document.querySelectorAll('.bdc-pill');
    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        var filter = this.getAttribute('data-filter') || '';
        pills.forEach(function (p) { p.classList.remove('bdc-pill--active'); });
        this.classList.add('bdc-pill--active');
        filterProducts(filter);
      });
    });
  }

  onReady(initPills);
})();
</script>

{% endif %}

{% schema %}
{
  "name": "BigDawgs Collection Hero",
  "settings": []
}
{% endschema %}