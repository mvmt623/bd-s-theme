<!-- TRUST BAR -->
<div class="bd-trust-bar">
  <div class="bd-trust-inner">
    <div class="bd-trust-item"><strong>500+</strong>Happy Customers</div>
    <div class="bd-trust-item"><strong>★★★★★</strong>5-Star Reviews</div>
    <div class="bd-trust-item"><strong>2 Holder Types</strong>One Touch &amp; Toploader</div>
    <div class="bd-trust-item"><strong>3 Finishes</strong>Matte · Holo · Cracked Ice</div>
    <div class="bd-trust-item"><strong>Collector-Built</strong>We Live the Hobby</div>
  </div>
</div>

<!-- PRODUCTS -->
<section class="bd-section bd-section-white" id="bd-products">
  <div class="bd-section-inner">
    <h2>Choose Your Style</h2>
    <p class="bd-section-sub">Every sticker is custom-printed with your logo. Pick your holder type, finish, and size — then upload your artwork.</p>
    <div class="bd-products-grid">
      <div class="bd-product-card">
        <span class="bd-finish-tag bd-tag-regular">Matte</span>
        <h3>One Touch Matte Stickers</h3>
        <p>Clean, professional finish for One Touch holders. Sharp print, crisp look.</p>
        <a href="{{ routes.root_url }}products/custom-card-stickers" class="bd-card-link">Build My Matte Order &rarr;</a>
      </div>
      <div class="bd-product-card">
        <span class="bd-finish-tag bd-tag-holo">Holographic</span>
