{% comment %}
  BIG DAWGS - Custom Flat Stickers Product Form
  4-step configurator: Size → Finish → Quantity → Artwork & Cut Type
  Sizes: 2×2, 3×3 only (dimension-based, no S/M/L)
  Pricing from quantityTiers JS object; variant matching by option1(size) + option2(finish) + option3(qty)
  Holo and Cracked Ice share Shopify variants (finish category "holo"); actual finish in cart properties.
{% endcomment %}

{%- liquid
  assign product_obj = product
  if product_obj == empty
    assign product_obj = all_products['custom-flat-stickers']
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000; --bd-red-dark: #990000;
    --bd-gold: #D4A017; --bd-black: #111111;
    --bd-dark: #1A1A1A; --bd-gray: #333333;
    --bd-light: #F5F5F5; --bd-white: #FFFFFF;
  }
  * { box-sizing: border-box; }

  .bdf-container {
    background: var(--bd-black); color: var(--bd-white);
    padding: 40px 20px; border-radius: 8px;
    max-width: 800px; margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  /* Progress bar */
  .bdf-progress { display: flex; gap: 8px; margin-bottom: 36px; }
  .bdf-dot {
    flex: 1; height: 4px; background: var(--bd-gray);
    border-radius: 2px; transition: background .3s;
  }
  .bdf-dot.active { background: var(--bd-red); }
  .bdf-dot.done   { background: var(--bd-gold); }

  /* Summary strip */
  .bdf-summary {
    display: none; background: var(--bd-dark);
    border: 1px solid var(--bd-gray); border-radius: 6px;
    padding: 14px; margin-bottom: 28px;
  }
  .bdf-summary.show { display: block; }
  .bdf-sum-row {
    display: flex; justify-content: space-between;
    padding: 5px 0; font-size: 14px; color: var(--bd-light);
  }
  .bdf-sum-row strong { color: var(--bd-white); }
  .bdf-sum-price { color: var(--bd-gold); font-weight: 700; }

  /* Steps */
  .bdf-step { display: none; animation: bdfIn .3s ease; }
  .bdf-step.active { display: block; }
  @keyframes bdfIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .bdf-heading { font-size: 26px; font-weight: 700; margin-bottom: 8px; }
  .bdf-sub     { font-size: 14px; color: #aaa; margin-bottom: 28px; line-height: 1.5; }

  /* Size cards — 2 columns */
  .bdf-size-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 16px; margin-bottom: 28px;
  }
  @media (max-width: 480px) { .bdf-size-grid { grid-template-columns: 1fr; } }

  .bdf-size-card {
    border: 2px solid var(--bd-gray); border-radius: 8px;
    padding: 28px 16px; text-align: center; cursor: pointer;
    background: var(--bd-dark); transition: all .25s;
  }
  .bdf-size-card:hover { border-color: var(--bd-red); transform: translateY(-2px); }
  .bdf-size-card.selected {
    border-color: var(--bd-red); background: rgba(204,0,0,.1);
    box-shadow: 0 0 16px rgba(204,0,0,.25);
  }
  .bdf-size-visual {
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px; background: rgba(255,255,255,.08);
    border-radius: 4px;
  }
  .bdf-size-label { font-size: 22px; font-weight: 800; color: var(--bd-white); }
  .bdf-size-dim   { font-size: 12px; color: #888; margin-top: 4px; }
  .bdf-size-from  { font-size: 13px; color: var(--bd-gold); margin-top: 8px; font-weight: 600; }

  /* Finish grid */
  .bdf-finish-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px; margin-bottom: 28px;
  }
  @media (max-width: 560px) { .bdf-finish-grid { grid-template-columns: 1fr; } }
  .bdf-finish-card {
    border: 2px solid var(--bd-gray); border-radius: 8px;
    padding: 24px 16px; text-align: center; cursor: pointer;
    background: var(--bd-dark); transition: all .25s;
  }
  .bdf-finish-card:hover { border-color: var(--bd-red); transform: translateY(-2px); }
  .bdf-finish-card.selected {
    border-color: var(--bd-red); background: rgba(204,0,0,.1);
    box-shadow: 0 0 16px rgba(204,0,0,.25);
  }
  .bdf-finish-name  { font-size: 16px; font-weight: 700; color: var(--bd-white); margin-bottom: 6px; }
  .bdf-finish-desc  { font-size: 12px; color: #aaa; margin-bottom: 8px; line-height: 1.5; }
  .bdf-finish-price { font-size: 14px; color: var(--bd-gold); font-weight: 700; }

  /* Quantity table — mirrors custom card stickers */
  .bdf-qty-note {
    background: var(--bd-dark); border-left: 3px solid var(--bd-gold);
    padding: 12px 16px; border-radius: 4px;
    font-size: 13px; color: var(--bd-light); margin-bottom: 24px;
  }
  .bdf-qty-table {
    width: 100%; border-collapse: collapse;
    margin-bottom: 28px; background: var(--bd-dark);
    border-radius: 8px; overflow: hidden;
  }
  .bdf-qty-table thead { background: var(--bd-gray); }
  .bdf-qty-table th {
    padding: 12px; text-align: left; font-weight: 700;
    font-size: 13px; text-transform: uppercase;
  }
  .bdf-qty-table td {
    padding: 14px 12px; border-top: 1px solid var(--bd-gray);
  }
  .bdf-qty-row { cursor: pointer; transition: background .2s; }
  .bdf-qty-row:hover { background: rgba(204,0,0,.1); }
  .bdf-qty-row.selected { background: rgba(204,0,0,.2); border-left: 4px solid var(--bd-red); }
  .bdf-qty-table td:first-child { padding-left: 16px; }
  .bdf-qty-badge {
    background: var(--bd-gold); color: var(--bd-black);
    padding: 3px 10px; border-radius: 12px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    margin-left: 8px; display: inline-block;
  }
  .bdf-qty-badge-popular {
    background: var(--bd-red); color: #fff;
    padding: 3px 10px; border-radius: 12px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    margin-left: 8px; display: inline-block;
  }
  .bdf-qty-price { font-weight: 700; color: var(--bd-gold); font-size: 16px; }

  /* Artwork upload */
  .bdf-field { margin-bottom: 22px; }
  .bdf-field label {
    display: block; font-weight: 600; font-size: 14px;
    margin-bottom: 8px; color: var(--bd-white);
  }
  .bdf-upload-zone {
    border: 2px dashed var(--bd-gray); border-radius: 10px;
    padding: 2rem 1.5rem; text-align: center; cursor: pointer;
    background: var(--bd-dark); transition: .25s; position: relative;
    margin-bottom: 12px;
  }
  .bdf-upload-zone:hover, .bdf-upload-zone.drag-over {
    border-color: var(--bd-red); background: rgba(204,0,0,.05);
  }
  .bdf-upload-zone.has-file { border-color: #2a7a2a; background: rgba(0,100,0,.08); border-style: solid; }
  .bdf-file-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; font-size: 0; }
  .bdf-upload-icon  { font-size: 2.2rem; margin-bottom: .6rem; pointer-events: none; }
  .bdf-upload-title { font-size: .95rem; font-weight: 700; color: var(--bd-white); margin: 0 0 4px; pointer-events: none; }
  .bdf-upload-hint  { font-size: .82rem; color: #aaa; margin: 0 0 6px; pointer-events: none; }
  .bdf-upload-fmt   { font-size: .72rem; color: #666; margin: 0; pointer-events: none; }
  .bdf-upload-preview {
    display: none; margin-top: 10px; padding: 10px 14px;
    background: #222; border-radius: 6px;
    align-items: center; gap: 10px;
  }
  .bdf-upload-preview.show { display: flex; }
  .bdf-preview-info { flex: 1; text-align: left; }
  .bdf-preview-name { color: var(--bd-white); font-size: 13px; font-weight: 600; }
  .bdf-preview-size { color: #888; font-size: 11px; margin-top: 2px; }
  .bdf-remove-btn { background: none; border: 1px solid #444; color: #888; font-size: 11px; padding: 4px 10px; border-radius: 4px; cursor: pointer; transition: all .2s; }
  .bdf-remove-btn:hover { border-color: var(--bd-red); color: #fff; }

  .bdf-upload-success {
    display: none; align-items: center; gap: 8px;
    background: rgba(0,120,0,.15); border: 1px solid #1a5c1a;
    border-radius: 6px; padding: 10px 14px;
    font-size: 12px; color: #7ddf7d; margin-bottom: 20px;
  }
  .bdf-upload-success.show { display: flex; }

  /* Cut type radios */
  .bdf-cut-group { margin-bottom: 22px; }
  .bdf-cut-group label.bdf-cut-label {
    font-size: 14px; font-weight: 600; color: var(--bd-white);
    display: block; margin-bottom: 10px;
  }
  .bdf-cut-options { display: flex; gap: 12px; flex-wrap: wrap; }
  .bdf-cut-option {
    flex: 1; min-width: 100px;
    border: 2px solid var(--bd-gray); border-radius: 8px;
    padding: 14px 12px; text-align: center; cursor: pointer;
    background: var(--bd-dark); transition: all .25s;
  }
  .bdf-cut-option:hover { border-color: var(--bd-red); }
  .bdf-cut-option.selected {
    border-color: var(--bd-red); background: rgba(204,0,0,.1);
    box-shadow: 0 0 12px rgba(204,0,0,.2);
  }
  .bdf-cut-option input { display: none; }
  .bdf-cut-icon { font-size: 1.4rem; margin-bottom: 4px; }
  .bdf-cut-name { font-size: 13px; font-weight: 700; color: var(--bd-white); }
  .bdf-cut-desc { font-size: 11px; color: #888; margin-top: 2px; }

  /* Fine print */
  .bdf-fine-print {
    font-size: 11px; color: #666; margin-bottom: 24px;
    padding: 8px 12px; background: var(--bd-dark);
    border-radius: 4px; border-left: 3px solid #444;
  }

  /* Actions */
  .bdf-actions { display: flex; gap: 12px; margin-top: 36px; }
  .bdf-btn {
    flex: 1; padding: 14px 24px; border: none; border-radius: 6px;
    font-size: 16px; font-weight: 700; cursor: pointer;
    text-transform: uppercase; transition: all .25s;
  }
  .bdf-btn-primary { background: var(--bd-red); color: var(--bd-white); }
  .bdf-btn-primary:hover:not(:disabled) {
    background: var(--bd-red-dark); transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(204,0,0,.4);
  }
  .bdf-btn-primary:disabled { background: var(--bd-gray); opacity: .5; cursor: not-allowed; }
  .bdf-btn-back {
    flex: 0 0 110px; background: var(--bd-dark); color: var(--bd-white);
    border: 1px solid var(--bd-gray);
  }
  .bdf-btn-back:hover { border-color: var(--bd-red); color: var(--bd-red); }
  .bdf-spinner {
    display: inline-block; width: 15px; height: 15px;
    border: 2px solid var(--bd-gold); border-top-color: transparent;
    border-radius: 50%; animation: bdfSpin .6s linear infinite; margin-right: 7px;
    vertical-align: middle;
  }
  @keyframes bdfSpin { to { transform: rotate(360deg); } }

  @media (max-width: 600px) {
    .bdf-container { padding: 24px 16px; }
    .bdf-heading { font-size: 22px; }
    .bdf-actions { flex-direction: column; }
    .bdf-btn-back { flex: 1; width: 100%; }
    .bdf-cut-options { flex-direction: column; }
  }
</style>

{% render 'finish-effects' %}

<div class="bdf-container">
  <div class="bdf-progress">
    <div class="bdf-dot active" data-step="1"></div>
    <div class="bdf-dot" data-step="2"></div>
    <div class="bdf-dot" data-step="3"></div>
    <div class="bdf-dot" data-step="4"></div>
  </div>

  <div class="bdf-summary" id="bdf-summary">
    <div class="bdf-sum-row"><strong>Size:</strong><span id="bdf-sum-size">—</span></div>
    <div class="bdf-sum-row"><strong>Finish:</strong><span id="bdf-sum-finish">—</span></div>
    <div class="bdf-sum-row"><strong>Quantity:</strong><span id="bdf-sum-qty">—</span></div>
    <div class="bdf-sum-row"><strong>Price:</strong><span id="bdf-sum-price" class="bdf-sum-price">—</span></div>
  </div>

  <form id="bdf-form" action="/cart/add" method="post">

    <!-- STEP 1: SIZE -->
    <div class="bdf-step active" data-step="1">
      <h2 class="bdf-heading">Select Size</h2>
      <p class="bdf-sub">Choose your sticker dimensions — perfect for packaging, laptops, water bottles, and more.</p>

      <div class="bdf-fine-print">Length of sticker is determined by the longest side.</div>

      <div class="bdf-size-grid">
        <div class="bdf-size-card" data-value="2x2">
          <div class="bdf-size-visual" style="width:52px;height:52px;"></div>
          <div class="bdf-size-label">2" × 2"</div>
          <div class="bdf-size-dim">Compact</div>
          <div class="bdf-size-from">Starting at $10</div>
        </div>
        <div class="bdf-size-card" data-value="3x3">
          <div class="bdf-size-visual" style="width:72px;height:72px;"></div>
          <div class="bdf-size-label">3" × 3"</div>
          <div class="bdf-size-dim">Standard</div>
          <div class="bdf-size-from">Starting at $5</div>
        </div>
      </div>

      <div class="bdf-actions">
        <button type="button" class="bdf-btn bdf-btn-primary" id="bdf-s1-next">Continue</button>
      </div>
    </div>

    <!-- STEP 2: FINISH -->
    <div class="bdf-step" data-step="2">
      <h2 class="bdf-heading">Select Finish</h2>
      <p class="bdf-sub">Choose the look that fits your brand — starting prices shown for your selected size.</p>

      <div class="bdf-finish-grid">
        <div class="bdf-finish-card" data-value="Matte">
          <div class="bdf-finish-name"><span class="bd-ftag bd-ftag--matte">Matte</span></div>
          <div class="bdf-finish-desc">Clean matte vinyl — professional and sharp</div>
          <div class="bdf-finish-price" id="bdf-price-matte">—</div>
        </div>
        <div class="bdf-finish-card" data-value="Holographic">
          <div class="bdf-finish-name"><span class="bd-ftag bd-ftag--holo">Holographic</span></div>
          <div class="bdf-finish-desc">Full rainbow color-shift — impossible to ignore</div>
          <div class="bdf-finish-price" id="bdf-price-holo">—</div>
        </div>
        <div class="bdf-finish-card" data-value="Cracked Ice">
          <div class="bdf-finish-name">
            <span class="bd-ftag bd-ftag--ice">
              <span class="bd-ftag-text">Cracked Ice</span>
              <svg class="bd-ftag-ice-svg" viewBox="0 0 100 28" preserveAspectRatio="none">{% render 'finish-ice-svg' %}</svg>
            </span>
          </div>
          <div class="bdf-finish-desc">Unique fractured-crystal pattern — bold and distinct</div>
          <div class="bdf-finish-price" id="bdf-price-ice">—</div>
        </div>
      </div>

      <div class="bdf-actions">
        <button type="button" class="bdf-btn bdf-btn-back" id="bdf-s2-back">Back</button>
        <button type="button" class="bdf-btn bdf-btn-primary" id="bdf-s2-next">Continue</button>
      </div>
    </div>

    <!-- STEP 3: QUANTITY -->
    <div class="bdf-step" data-step="3">
      <h2 class="bdf-heading">Select Quantity</h2>
      <p class="bdf-sub">Choose your order quantity — bigger tiers = more per dollar.</p>

      <div class="bdf-qty-note">All prices shown are flat — no hidden fees. Select the tier that works for you.</div>

      <table class="bdf-qty-table">
        <thead>
          <tr>
            <th>Quantity</th>
            <th>Price</th>
            <th>Per Sticker</th>
          </tr>
        </thead>
        <tbody id="bdf-qty-tbody">
          <!-- Populated by JS -->
        </tbody>
      </table>

      <div class="bdf-actions">
        <button type="button" class="bdf-btn bdf-btn-back" id="bdf-s3-back">Back</button>
        <button type="button" class="bdf-btn bdf-btn-primary" id="bdf-s3-next">Continue</button>
      </div>
    </div>

    <!-- STEP 4: ARTWORK + CUT TYPE -->
    <div class="bdf-step" data-step="4">
      <h2 class="bdf-heading">Artwork &amp; Cut Type</h2>
      <p class="bdf-sub">Upload your design and choose your cut shape — we'll confirm before printing.</p>

      <div class="bdf-field">
        <label>Primary Artwork <span style="color:var(--bd-red);font-weight:800;">*</span></label>
        <div class="bdf-upload-zone" id="bdf-upload-zone">
          <input type="file" class="bdf-file-input" id="bdf-file-input"
            accept="image/*,.pdf,.ai,.psd,.eps">
          <div class="bdf-upload-icon" id="bdf-upload-icon">📁</div>
          <p class="bdf-upload-title" id="bdf-upload-title">Upload Your Artwork</p>
          <p class="bdf-upload-hint" id="bdf-upload-hint">Drag &amp; drop or tap to browse — mobile camera supported</p>
          <p class="bdf-upload-fmt">PNG, JPG, PDF, AI, PSD · Any size · 300 DPI+ preferred</p>
        </div>
        <div class="bdf-upload-preview" id="bdf-upload-preview">
          <div class="bdf-preview-info">
            <div class="bdf-preview-name" id="bdf-preview-name">—</div>
            <div class="bdf-preview-size" id="bdf-preview-size">—</div>
          </div>
          <button type="button" class="bdf-remove-btn" id="bdf-remove-btn" title="Remove">Remove</button>
        </div>
        <div class="bdf-upload-success" id="bdf-upload-success">
          <span>✓</span>
          <span id="bdf-success-text">Artwork noted — we'll email you to collect it securely after your order.</span>
        </div>
      </div>

      <div class="bdf-cut-group">
        <label class="bdf-cut-label">Cut Type <span style="color:var(--bd-red);font-weight:800;">*</span></label>
        <div class="bdf-cut-options" id="bdf-cut-options">
          <div class="bdf-cut-option" data-cut="Die-Cut">
            <input type="radio" name="properties[Cut Type]" value="Die-Cut">
            <div class="bdf-cut-icon">✂️</div>
            <div class="bdf-cut-name">Die-Cut</div>
            <div class="bdf-cut-desc">Custom shape around your design</div>
          </div>
          <div class="bdf-cut-option" data-cut="Circle">
            <input type="radio" name="properties[Cut Type]" value="Circle">
            <div class="bdf-cut-icon">⭕</div>
            <div class="bdf-cut-name">Circle</div>
            <div class="bdf-cut-desc">Clean round cut</div>
          </div>
          <div class="bdf-cut-option" data-cut="Square">
            <input type="radio" name="properties[Cut Type]" value="Square">
            <div class="bdf-cut-icon">⬜</div>
            <div class="bdf-cut-name">Square</div>
            <div class="bdf-cut-desc">Standard square or rectangle</div>
          </div>
        </div>
      </div>

      <!-- Hidden cart fields -->
      <input type="hidden" name="id"                     id="bdf-variant-id"    value="">
      <input type="hidden" name="quantity"                                      value="1">
      <input type="hidden" name="properties[Size]"       id="bdf-prop-size"    value="">
      <input type="hidden" name="properties[Finish]"     id="bdf-prop-finish"  value="">
      <input type="hidden" name="properties[Quantity]"   id="bdf-prop-qty"     value="">
      <input type="hidden" name="properties[Artwork]"    id="bdf-prop-artwork" value="">

      <div class="bdf-actions">
        <button type="button" class="bdf-btn bdf-btn-back" id="bdf-s4-back">Back</button>
        <button type="submit" class="bdf-btn bdf-btn-primary" id="bdf-submit" disabled>
          Upload Artwork &amp; Select Cut Type to Continue
        </button>
      </div>
    </div>

  </form>
</div>

<script>
(function() {
  // ── PRICING DATA ──
  // Key format: "size|finishCategory"  (finishCategory: "regular" or "holo")
  // Holographic and Cracked Ice share the same price tiers (both = "holo" category)
  // Each tier: { qty, price, best }  — from Big Dawgs Pricing Sheet (Sheet3)
  var quantityTiers = {
    // ── 2×2 — MATTE ──
    "2x2|regular": [
      {qty:15, price:10},
      {qty:50, price:20},
      {qty:100, price:35},
      {qty:250, price:80, best:true},
      {qty:500, price:150}
    ],
    // ── 2×2 — HOLO / CRACKED ICE ──
    "2x2|holo": [
      {qty:15, price:13},
      {qty:50, price:25},
      {qty:100, price:45},
      {qty:250, price:100, best:true},
      {qty:500, price:175}
    ],
    // ── 3×3 — MATTE ──
    "3x3|regular": [
      {qty:6,   price:5},
      {qty:24,  price:18},
      {qty:48,  price:32},
      {qty:100, price:60},
      {qty:250, price:135, best:true},
      {qty:500, price:250}
    ],
    // ── 3×3 — HOLO / CRACKED ICE ──
    "3x3|holo": [
      {qty:6,   price:6},
      {qty:24,  price:20},
      {qty:48,  price:36},
      {qty:100, price:70},
      {qty:250, price:150, best:true},
      {qty:500, price:275}
    ]
  };

  function getFinishCategory(finish) {
    if (finish === 'Holographic' || finish === 'Cracked Ice') return 'holo';
    return 'regular';
  }

  // ═══════════════════════════════════════════════
  // TESTING MODE — flip to false to enforce artwork
  var TESTING_MODE = true;
  // ═══════════════════════════════════════════════

  // Product variants from Shopify
  var variants = {{ product_obj.variants | json }} || [];

  // Form state
  var state = {
    size: null,       // "2x2" or "3x3"
    finish: null,     // "Matte", "Holographic", or "Cracked Ice"
    quantity: null,   // Number
    price: null,      // Number (dollars)
    artworkFile: null,
    cutType: null,
    variantId: null
  };

  // ── VARIANT MATCHING ──
  // Uses option-based matching: option1=size, option2=finish category name, option3=quantity
  // This avoids price collision issues between different size/finish combos
  function findVariant(size, finish, qty) {
    var finishCat = getFinishCategory(finish);
    // Try exact option match first
    var match = null;
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      // option1 = size (e.g., "2x2"), option2 = finish category (e.g., "Matte" or "Holo"), option3 = qty string
      if (v.option1 === size && v.option2 === (finishCat === 'regular' ? 'Matte' : 'Holo') && String(v.option3) === String(qty)) {
        return v;
      }
    }
    // Fallback: price-based matching (safety net)
    var targetPrice = null;
    var key = size + '|' + finishCat;
    var tiers = quantityTiers[key];
    if (tiers) {
      for (var j = 0; j < tiers.length; j++) {
        if (tiers[j].qty === qty) { targetPrice = tiers[j].price; break; }
      }
    }
    if (targetPrice !== null) {
      var targetCents = targetPrice * 100;
      for (var k = 0; k < variants.length; k++) {
        if (variants[k].price === targetCents) return variants[k];
      }
    }
    return null;
  }

  // ── STEP NAVIGATION ──
  function goStep(n) {
    document.querySelectorAll('.bdf-step').forEach(function(s) { s.classList.remove('active'); });
    document.querySelector('.bdf-step[data-step="' + n + '"]').classList.add('active');
    document.querySelectorAll('.bdf-dot').forEach(function(d, i) {
      d.classList.remove('active','done');
      var ds = i + 1;
      if (ds === n) d.classList.add('active');
      else if (ds < n) d.classList.add('done');
    });
    if (n > 1) document.getElementById('bdf-summary').classList.add('show');
    else document.getElementById('bdf-summary').classList.remove('show');
    if (n === 3) populateQuantityTable();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateSummary() {
    var sizeLabel = state.size === '2x2' ? '2" × 2"' : (state.size === '3x3' ? '3" × 3"' : '—');
    document.getElementById('bdf-sum-size').textContent = sizeLabel;
    document.getElementById('bdf-sum-finish').textContent = state.finish || '—';
    document.getElementById('bdf-sum-qty').textContent = state.quantity ? (state.quantity + ' stickers') : '—';
    document.getElementById('bdf-sum-price').textContent = state.price ? ('$' + state.price) : '—';
  }

  // ── STEP 1: SIZE SELECTION ──
  document.querySelectorAll('.bdf-size-card').forEach(function(card) {
    card.addEventListener('click', function() {
      document.querySelectorAll('.bdf-size-card').forEach(function(c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      state.size = this.dataset.value;
      // Reset downstream
      state.finish = null; state.quantity = null; state.price = null;
      document.querySelectorAll('.bdf-finish-card').forEach(function(c) { c.classList.remove('selected'); });
      updateSummary();
    });
  });

  document.getElementById('bdf-s1-next').addEventListener('click', function() {
    if (!state.size) { alert('Please select a size.'); return; }
    updateFinishPrices();
    goStep(2);
  });

  // ── STEP 2: FINISH SELECTION ──
  function updateFinishPrices() {
    var items = [
      { finish: 'Matte',       priceId: 'bdf-price-matte', cat: 'regular' },
      { finish: 'Holographic', priceId: 'bdf-price-holo',  cat: 'holo' },
      { finish: 'Cracked Ice', priceId: 'bdf-price-ice',   cat: 'holo' }
    ];
    items.forEach(function(item) {
      var key = state.size + '|' + item.cat;
      var tiers = quantityTiers[key];
      var el = document.getElementById(item.priceId);
      if (tiers && tiers.length) {
        el.textContent = 'From $' + tiers[0].price;
        el.style.color = 'var(--bd-gold)';
      } else {
        el.textContent = 'Unavailable';
        el.style.color = '#666';
      }
    });
  }

  document.querySelectorAll('.bdf-finish-card').forEach(function(card) {
    card.addEventListener('click', function() {
      document.querySelectorAll('.bdf-finish-card').forEach(function(c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      state.finish = this.dataset.value;
      // Reset downstream
      state.quantity = null; state.price = null;
      updateSummary();
    });
  });

  document.getElementById('bdf-s2-back').addEventListener('click', function() { goStep(1); });
  document.getElementById('bdf-s2-next').addEventListener('click', function() {
    if (!state.finish) { alert('Please select a finish.'); return; }
    goStep(3);
  });

  // ── STEP 3: QUANTITY SELECTION ──
  function populateQuantityTable() {
    var finishCat = getFinishCategory(state.finish);
    var key = state.size + '|' + finishCat;
    var tiers = quantityTiers[key];
    var tbody = document.getElementById('bdf-qty-tbody');
    tbody.innerHTML = '';

    if (!tiers || !tiers.length) {
      tbody.innerHTML = '<tr><td colspan="3" style="color:#888;text-align:center;padding:20px;">Contact us for pricing on this combination.</td></tr>';
      return;
    }

    // Find "Most Popular" tier: highest qty where price ≤ $100
    var popularQty = null;
    for (var p = tiers.length - 1; p >= 0; p--) {
      if (tiers[p].price <= 100) { popularQty = tiers[p].qty; break; }
    }

    tiers.forEach(function(tier) {
      var row = document.createElement('tr');
      row.className = 'bdf-qty-row';
      if (state.quantity === tier.qty) row.classList.add('selected');

      var qtyCell = document.createElement('td');
      qtyCell.innerHTML = tier.qty + ' stickers';
      if (tier.qty === popularQty) qtyCell.innerHTML += '<span class="bdf-qty-badge-popular">Most Popular</span>';
      if (tier.best) qtyCell.innerHTML += '<span class="bdf-qty-badge">Best Value</span>';

      var priceCell = document.createElement('td');
      priceCell.innerHTML = '<span class="bdf-qty-price">$' + tier.price + '</span>';

      var perCell = document.createElement('td');
      var per = (tier.price / tier.qty);
      perCell.textContent = per < 0.01 ? '<$0.01' : '$' + per.toFixed(2);
      perCell.style.color = '#888';
      perCell.style.fontSize = '13px';

      row.appendChild(qtyCell);
      row.appendChild(priceCell);
      row.appendChild(perCell);

      row.addEventListener('click', function() {
        state.quantity = tier.qty;
        state.price = tier.price;
        document.querySelectorAll('.bdf-qty-row').forEach(function(r) { r.classList.remove('selected'); });
        row.classList.add('selected');
        updateSummary();
      });

      tbody.appendChild(row);
    });
  }

  document.getElementById('bdf-s3-back').addEventListener('click', function() { goStep(2); });
  document.getElementById('bdf-s3-next').addEventListener('click', function() {
    if (!state.quantity) { alert('Please select a quantity tier.'); return; }
    goStep(4);
  });

  // ── STEP 4: ARTWORK + CUT TYPE ──
  var zone      = document.getElementById('bdf-upload-zone');
  var fileInput = document.getElementById('bdf-file-input');
  var preview   = document.getElementById('bdf-upload-preview');
  var successBg = document.getElementById('bdf-upload-success');
  var submitBtn = document.getElementById('bdf-submit');

  var isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
  (function() {
    var hint = document.getElementById('bdf-upload-hint');
    if (hint) hint.textContent = isMobile ? 'Tap to choose a file or take a photo' : 'Drag & drop or click to browse';
  })();

  zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('drag-over'); });
  zone.addEventListener('dragleave', function() { zone.classList.remove('drag-over'); });
  zone.addEventListener('drop', function(e) {
    e.preventDefault(); zone.classList.remove('drag-over');
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', function() {
    if (this.files[0]) handleFile(this.files[0]);
  });
  document.getElementById('bdf-remove-btn').addEventListener('click', function(e) {
    e.stopPropagation(); clearUpload();
  });

  function handleFile(file) {
    state.artworkFile = file.name;
    zone.classList.add('has-file');
    document.getElementById('bdf-preview-name').textContent = file.name;
    document.getElementById('bdf-preview-size').textContent = formatBytes(file.size);
    document.getElementById('bdf-upload-title').textContent = '✓ File ready';
    document.getElementById('bdf-upload-hint').textContent = file.name;
    preview.classList.add('show');
    successBg.classList.add('show');
    document.getElementById('bdf-success-text').textContent =
      '"' + file.name + '" selected — we\'ll email you to collect your artwork securely after your order.';
    updateSubmitState();
  }

  function clearUpload() {
    state.artworkFile = null;
    zone.classList.remove('has-file');
    preview.classList.remove('show');
    successBg.classList.remove('show');
    fileInput.value = '';
    document.getElementById('bdf-upload-title').textContent = 'Upload Your Artwork';
    document.getElementById('bdf-upload-hint').textContent = isMobile ? 'Tap to choose a file or take a photo' : 'Drag & drop or click to browse';
    updateSubmitState();
  }

  // Cut type
  document.querySelectorAll('.bdf-cut-option').forEach(function(opt) {
    opt.addEventListener('click', function() {
      document.querySelectorAll('.bdf-cut-option').forEach(function(o) { o.classList.remove('selected'); });
      this.classList.add('selected');
      this.querySelector('input').checked = true;
      state.cutType = this.dataset.cut;
      updateSubmitState();
    });
  });

  function updateSubmitState() {
    var ready = (state.artworkFile || TESTING_MODE) && state.cutType;
    if (ready) {
      submitBtn.textContent = 'Add to Cart — $' + state.price;
      submitBtn.disabled = false;
    } else {
      var msg = [];
      if (!state.artworkFile && !TESTING_MODE) msg.push('Upload Artwork');
      if (!state.cutType) msg.push('Select Cut Type');
      submitBtn.textContent = msg.join(' & ') + ' to Continue';
      submitBtn.disabled = true;
    }
  }

  document.getElementById('bdf-s4-back').addEventListener('click', function() { goStep(3); });

  // ── FORM SUBMIT ──
  document.getElementById('bdf-form').addEventListener('submit', function(e) {
    e.preventDefault();
    if (!state.size || !state.finish || !state.quantity) {
      alert('Please complete all steps before submitting.'); return;
    }
    if (!TESTING_MODE && !state.artworkFile) {
      alert('Please upload your artwork file to continue.'); return;
    }
    if (!state.cutType) {
      alert('Please select a cut type to continue.'); return;
    }

    // Find variant
    var variant = findVariant(state.size, state.finish, state.quantity);
    if (!variant) {
      alert('This combination isn\'t currently available. Please contact us for a custom quote.'); return;
    }

    document.getElementById('bdf-variant-id').value    = variant.id;
    document.getElementById('bdf-prop-size').value      = state.size === '2x2' ? '2" × 2"' : '3" × 3"';
    document.getElementById('bdf-prop-finish').value    = state.finish;
    document.getElementById('bdf-prop-qty').value       = state.quantity + ' stickers';
    document.getElementById('bdf-prop-artwork').value   = state.artworkFile
      ? 'File: ' + state.artworkFile + ' (will be emailed)'
      : '';

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="bdf-spinner"></span>Adding to Cart...';
    setTimeout(function() { e.target.submit(); }, 400);
  });

  function formatBytes(b) {
    if (b < 1024)    return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  // ── PRE-SELECT MOST POPULAR OPTIONS ──
  // Size: 3x3 (Standard), Finish: Cracked Ice (most popular)
  (function() {
    var defaultSize = document.querySelector('.bdf-size-card[data-value="3x3"]');
    if (defaultSize) {
      defaultSize.classList.add('selected');
      state.size = '3x3';
      updateSummary();
    }
    // Pre-select Cracked Ice so it's highlighted when user reaches Step 2
    var defaultFinish = document.querySelector('.bdf-finish-card[data-value="Cracked Ice"]');
    if (defaultFinish) {
      defaultFinish.classList.add('selected');
      state.finish = 'Cracked Ice';
      updateSummary();
    }
  })();
})();
</script>

