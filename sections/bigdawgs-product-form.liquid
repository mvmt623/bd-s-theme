{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Toploader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), Wide size,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 30px;
    display: none;
  }

  .sticky-summary.visible {
    display: block;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-label {
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-step {
    display: none;
    animation: slideIn 0.3s ease-out;
  }

  .form-step.active {
    display: block;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .form-group {
    margin-bottom: 30px;
  }

  .form-label {
    display: block;
    margin-bottom: 10px;
    font-weight: 600;
    color: var(--bd-white);
    font-size: 14px;
  }

  .form-label.required::after {
    content: ' *';
    color: var(--bd-red);
  }

  .form-note {
    font-size: 12px;
    color: var(--bd-light);
    margin-top: 6px;
  }

  input[type="text"],
  input[type="number"],
  textarea,
  select {
    width: 100%;
    padding: 12px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 4px;
    color: var(--bd-white);
    font-family: inherit;
    font-size: 14px;
  }

  input[type="text"]::placeholder,
  textarea::placeholder {
    color: #666;
  }

  input[type="text"]:focus,
  input[type="number"]:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: var(--bd-red);
    box-shadow: 0 0 0 2px rgba(204, 0, 0, 0.1);
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  .checkbox-group,
  .radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }

  .checkbox-item,
  .radio-item {
    display: flex;
    align-items: center;
    cursor: pointer;
  }

  input[type="checkbox"],
  input[type="radio"] {
    margin-right: 8px;
    cursor: pointer;
    width: 18px;
    height: 18px;
    accent-color: var(--bd-red);
  }

  .checkbox-item label,
  .radio-item label {
    cursor: pointer;
    user-select: none;
  }

  .button-group {
    display: flex;
    gap: 12px;
    margin-top: 30px;
  }

  button {
    flex: 1;
    padding: 14px 20px;
    border: none;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background-color: var(--bd-red);
    color: var(--bd-white);
  }

  .btn-primary:hover {
    background-color: var(--bd-red-dark);
  }

  .btn-primary:disabled {
    background-color: #666;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .btn-secondary {
    background-color: var(--bd-gray);
    color: var(--bd-white);
  }

  .btn-secondary:hover {
    background-color: #444;
  }

  .file-upload-area {
    border: 2px dashed var(--bd-gray);
    border-radius: 6px;
    padding: 40px 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background-color: var(--bd-dark);
  }

  .file-upload-area:hover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.05);
  }

  .file-upload-area.dragover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .upload-icon {
    font-size: 48px;
    margin-bottom: 15px;
  }

  .upload-text {
    font-size: 14px;
    color: var(--bd-light);
  }

  .upload-text strong {
    color: var(--bd-white);
  }

  .file-list {
    margin-top: 20px;
    list-style: none;
    padding: 0;
  }

  .file-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 4px;
    margin-bottom: 8px;
    font-size: 14px;
  }

  .file-item button {
    flex: 0;
    padding: 6px 12px;
    background-color: var(--bd-red);
    color: var(--bd-white);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    font-size: 12px;
  }

  .file-item button:hover {
    background-color: var(--bd-red-dark);
  }

  .size-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 12px;
  }

  .size-option {
    position: relative;
  }

  .size-option input {
    display: none;
  }

  .size-option label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15px;
    background-color: var(--bd-dark);
    border: 2px solid var(--bd-gray);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .size-option input:checked + label {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .quantity-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 10px;
  }

  .quantity-option {
    position: relative;
  }

  .quantity-option input {
    display: none;
  }

  .quantity-option label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 15px 10px;
    background-color: var(--bd-dark);
    border: 2px solid var(--bd-gray);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .quantity-option input:checked + label {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .quantity-amount {
    font-size: 16px;
    font-weight: 600;
    color: var(--bd-white);
  }

  .quantity-price {
    font-size: 12px;
    color: var(--bd-light);
    margin-top: 4px;
  }

  .finish-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 12px;
  }

  .finish-option {
    position: relative;
  }

  .finish-option input {
    display: none;
  }

  .finish-option label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15px;
    background-color: var(--bd-dark);
    border: 2px solid var(--bd-gray);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .finish-option input:checked + label {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .error-message {
    color: var(--bd-red);
    font-size: 13px;
    margin-top: 6px;
  }

  .success-message {
    background-color: rgba(0, 100, 0, 0.1);
    border: 1px solid #0a0;
    color: #0f0;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .loading-spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top: 2px solid white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 8px;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .preview-section {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 20px;
    margin-top: 30px;
  }

  .preview-item {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--bd-gray);
    font-size: 14px;
  }

  .preview-item:last-child {
    border-bottom: none;
  }

  .preview-label {
    color: var(--bd-light);
  }

  .preview-value {
    color: var(--bd-white);
    font-weight: 600;
  }

  .price-breakdown {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 2px solid var(--bd-gray);
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
  }

  .price-row.total {
    font-weight: 600;
    color: var(--bd-red);
    font-size: 16px;
  }
</style>

<div class="bigdawgs-form-container">
  <div class="form-progress-bar">
    <div class="progress-dot active" id="step1-dot"></div>
    <div class="progress-dot" id="step2-dot"></div>
    <div class="progress-dot" id="step3-dot"></div>
    <div class="progress-dot" id="step4-dot"></div>
    <div class="progress-dot" id="step5-dot"></div>
  </div>

  <div class="sticky-summary" id="sticky-summary">
    <div class="summary-item">
      <span class="summary-label">Size:</span>
      <span id="summary-size">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Holder Type:</span>
      <span id="summary-holder">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Finish:</span>
      <span id="summary-finish">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Quantity:</span>
      <span id="summary-quantity">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Total Price:</span>
      <span id="summary-price" style="color: var(--bd-red);">$0</span>
    </div>
  </div>

  <form id="bigdawgs-form" action="/cart/add" method="post">
    <!-- Step 1: Size -->
    <div class="form-step active" id="step1">
      <h2>Select Size</h2>
      <div class="form-group">
        <label class="form-label required">Which size would you like?</label>
        <div class="size-selector">
          <div class="size-option">
            <input type="radio" id="size-standard" name="size" value="standard" required>
            <label for="size-standard">Standard</label>
          </div>
          <div class="size-option">
            <input type="radio" id="size-wide" name="size" value="wide" required>
            <label for="size-wide">Wide</label>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 2: Holder Type -->
    <div class="form-step" id="step2">
      <h2>Holder Type</h2>
      <div class="form-group">
        <label class="form-label required">Which card holder do you use?</label>
        <div class="radio-group">
          <div class="radio-item">
            <input type="radio" id="holder-onetouch" name="holder_type" value="One Touch" required>
            <label for="holder-onetouch">One Touch</label>
          </div>
          <div class="radio-item">
            <input type="radio" id="holder-toploader" name="holder_type" value="Toploader" required>
            <label for="holder-toploader">Toploader</label>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 3: Finish -->
    <div class="form-step" id="step3">
      <h2>Select Finish</h2>
      <div class="form-group">
        <label class="form-label required">Choose your sticker finish</label>
        <div class="finish-selector">
          <div class="finish-option">
            <input type="radio" id="finish-regular" name="finish" value="Regular" required>
            <label for="finish-regular">Regular</label>
          </div>
          <div class="finish-option">
            <input type="radio" id="finish-holo" name="finish" value="Holo" required>
            <label for="finish-holo">Holo</label>
          </div>
          <div class="finish-option">
            <input type="radio" id="finish-crackedice" name="finish" value="Cracked Ice" required>
            <label for="finish-crackedice">Cracked Ice</label>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 4: Quantity & Upload -->
    <div class="form-step" id="step4">
      <h2>Choose Quantity & Upload Art</h2>

      <!-- Quantity Selection -->
      <div class="form-group">
        <label class="form-label required">How many stickers?</label>
        <div class="quantity-selector">
          <div class="quantity-option">
            <input type="radio" id="qty-25" name="quantity" value="25" required>
            <label for="qty-25">
              <span class="quantity-amount">25</span>
              <span class="quantity-price">$2.50</span>
            </label>
          </div>
          <div class="quantity-option">
            <input type="radio" id="qty-50" name="quantity" value="50" required>
            <label for="qty-50">
              <span class="quantity-amount">50</span>
              <span class="quantity-price">$4.00</span>
            </label>
          </div>
          <div class="quantity-option">
            <input type="radio" id="qty-100" name="quantity" value="100" required>
            <label for="qty-100">
              <span class="quantity-amount">100</span>
              <span class="quantity-price">$7.50</span>
            </label>
          </div>
          <div class="quantity-option">
            <input type="radio" id="qty-250" name="quantity" value="250" required>
            <label for="qty-250">
              <span class="quantity-amount">250</span>
              <span class="quantity-price">$15.00</span>
            </label>
          </div>
        </div>
        <p class="form-note">Prices are per sticker design. You can upload multiple designs.</p>
      </div>

      <!-- File Upload -->
      <div class="form-group">
        <label class="form-label required">Upload Your Design</label>
        <div class="file-upload-area" id="file-upload-area">
          <div class="upload-icon">📤</div>
          <div class="upload-text">
            <strong>Click to upload</strong> or drag and drop<br>
            PNG, JPG or GIF (Max 10MB)
          </div>
        </div>
        <input type="file" id="file-input" accept=".png,.jpg,.jpeg,.gif" multiple style="display: none;">
        <ul class="file-list" id="file-list"></ul>
        <p class="form-note">You can upload up to 5 different designs. Maximum 10MB per file.</p>
      </div>
    </div>

    <!-- Step 5: Review & Checkout -->
    <div class="form-step" id="step5">
      <h2>Review Your Order</h2>

      <div class="preview-section">
        <div class="preview-item">
          <span class="preview-label">Size:</span>
          <span class="preview-value" id="preview-size">-</span>
        </div>
        <div class="preview-item">
          <span class="preview-label">Holder Type:</span>
          <span class="preview-value" id="preview-holder">-</span>
        </div>
        <div class="preview-item">
          <span class="preview-label">Finish:</span>
          <span class="preview-value" id="preview-finish">-</span>
        </div>
        <div class="preview-item">
          <span class="preview-label">Number of Designs:</span>
          <span class="preview-value" id="preview-designs">-</span>
        </div>
        <div class="preview-item">
          <span class="preview-label">Quantity per Design:</span>
          <span class="preview-value" id="preview-quantity">-</span>
        </div>

        <div class="price-breakdown">
          <div class="price-row">
            <span>Base Price per Design:</span>
            <span id="price-base">$0.00</span>
          </div>
          <div class="price-row">
            <span>Number of Designs:</span>
            <span id="price-designs">1</span>
          </div>
          <div class="price-row total">
            <span>Total Price:</span>
            <span id="price-total">$0.00</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Navigation Buttons -->
    <div class="button-group" id="button-group">
      <button type="button" class="btn-secondary" id="prev-btn" style="display: none;">Back</button>
      <button type="button" class="btn-primary" id="next-btn">Next</button>
      <button type="submit" class="btn-primary" id="submit-btn" style="display: none;">Add to Cart</button>
    </div>

    <input type="hidden" name="id" id="variant-id" value="">
    <input type="hidden" name="quantity" id="form-quantity" value="">
    <input type="hidden" name="properties[Size]" id="form-size" value="">
    <input type="hidden" name="properties[Holder Type]" id="form-holder" value="">
    <input type="hidden" name="properties[Finish]" id="form-finish" value="">
    <input type="hidden" name="properties[Quantity per Design]" id="form-qty-per-design" value="">
    <input type="hidden" name="properties[Number of Designs]" id="form-num-designs" value="">
    <input type="hidden" name="properties[Uploaded Files]" id="form-files" value="">
  </form>
</div>

<script>
  let currentStep = 1;
  const totalSteps = 5;
  let uploadedFiles = [];

  const priceData = {
    25: 2.50,
    50: 4.00,
    100: 7.50,
    250: 15.00
  };

  const sizeMap = {
    'standard': { 'One Touch': 'custom-card-stickers-onetouch-standard-regular', 'Toploader': 'custom-card-stickers-toploader-standard-regular' },
    'wide': { 'One Touch': 'custom-card-stickers-onetouch-wide-regular', 'Toploader': 'custom-card-stickers-toploader-wide-regular' }
  };

  function showStep(step) {
    for (let i = 1; i <= totalSteps; i++) {
      const stepEl = document.getElementById(`step${i}`);
      if (stepEl) stepEl.classList.remove('active');
    }
    const activeStep = document.getElementById(`step${step}`);
    if (activeStep) activeStep.classList.add('active');

    // Update progress dots
    for (let i = 1; i <= totalSteps; i++) {
      const dot = document.getElementById(`step${i}-dot`);
      if (dot) {
        dot.classList.remove('active', 'completed');
        if (i < step) {
          dot.classList.add('completed');
        } else if (i === step) {
          dot.classList.add('active');
        }
      }
    }

    // Update button visibility
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const submitBtn = document.getElementById('submit-btn');
    if (prevBtn) prevBtn.style.display = step === 1 ? 'none' : 'block';
    if (nextBtn) nextBtn.style.display = step === totalSteps ? 'none' : 'block';
    if (submitBtn) submitBtn.style.display = step === totalSteps ? 'block' : 'none';

    if (step >= 2) {
      updateSummary();
      document.getElementById('sticky-summary').classList.add('visible');
    } else {
      document.getElementById('sticky-summary').classList.remove('visible');
    }
  }

  function updateSummary() {
    const size = document.querySelector('input[name="size"]:checked')?.value || '-';
    const holder = document.querySelector('input[name="holder_type"]:checked')?.value || '-';
    const finish = document.querySelector('input[name="finish"]:checked')?.value || '-';
    const quantity = document.querySelector('input[name="quantity"]:checked')?.value || '-';
    const price = quantity !== '-' ? (priceData[parseInt(quantity)] * uploadedFiles.length || priceData[parseInt(quantity)]) : 0;

    document.getElementById('summary-size').textContent = size;
    document.getElementById('summary-holder').textContent = holder;
    document.getElementById('summary-finish').textContent = finish;
    document.getElementById('summary-quantity').textContent = quantity;
    document.getElementById('summary-price').textContent = '$' + price.toFixed(2);
  }

  function validateStep(step) {
    if (step === 1) {
      return !!document.querySelector('input[name="size"]:checked');
    } else if (step === 2) {
      return !!document.querySelector('input[name="holder_type"]:checked');
    } else if (step === 3) {
      return !!document.querySelector('input[name="finish"]:checked');
    } else if (step === 4) {
      return !!document.querySelector('input[name="quantity"]:checked') && uploadedFiles.length > 0;
    }
    return true;
  }

  // File upload handling
  const fileUploadArea = document.getElementById('file-upload-area');
  const fileInput = document.getElementById('file-input');
  const fileList = document.getElementById('file-list');

  fileUploadArea.addEventListener('click', () => fileInput.click());

  fileUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    fileUploadArea.classList.add('dragover');
  });

  fileUploadArea.addEventListener('dragleave', () => {
    fileUploadArea.classList.remove('dragover');
  });

  fileUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    fileUploadArea.classList.remove('dragover');
    const files = Array.from(e.dataTransfer.files);
    handleFiles(files);
  });

  fileInput.addEventListener('change', (e) => {
    handleFiles(Array.from(e.target.files));
  });

  function handleFiles(files) {
    files.forEach(file => {
      if (file.size > 10 * 1024 * 1024) {
        alert('File ' + file.name + ' is too large (max 10MB)');
        return;
      }
      if (!['image/png', 'image/jpeg', 'image/gif'].includes(file.type)) {
        alert('File ' + file.name + ' must be PNG, JPG, or GIF');
        return;
      }
      uploadedFiles.push(file);
    });
    renderFileList();
    updatePricePreview();
  }

  function renderFileList() {
    fileList.innerHTML = '';
    uploadedFiles.forEach((file, index) => {
      const li = document.createElement('li');
      li.className = 'file-item';
      li.innerHTML = `
        <span>${file.name}</span>
        <button type="button" onclick="removeFile(${index})">Remove</button>
      `;
      fileList.appendChild(li);
    });
  }

  function removeFile(index) {
    uploadedFiles.splice(index, 1);
    renderFileList();
    updatePricePreview();
  }

  function updatePricePreview() {
    const quantity = parseInt(document.querySelector('input[name="quantity"]:checked')?.value || 25);
    const basePrice = priceData[quantity];
    const numDesigns = uploadedFiles.length;
    const totalPrice = basePrice * numDesigns;

    document.getElementById('price-base').textContent = '$' + basePrice.toFixed(2);
    document.getElementById('price-designs').textContent = numDesigns;
    document.getElementById('price-total').textContent = '$' + totalPrice.toFixed(2);

    // Update summary
    const summaryPrice = document.getElementById('summary-price');
    if (summaryPrice) summaryPrice.textContent = '$' + totalPrice.toFixed(2);
  }

  // Step navigation
  document.getElementById('prev-btn').addEventListener('click', () => {
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  });

  document.getElementById('next-btn').addEventListener('click', () => {
    if (validateStep(currentStep)) {
      currentStep++;
      showStep(currentStep);
      updatePreview();
    } else {
      alert('Please fill in all required fields for this step.');
    }
  });

  // Quantity change listener
  document.querySelectorAll('input[name="quantity"]').forEach(input => {
    input.addEventListener('change', updatePricePreview);
  });

  function updatePreview() {
    const size = document.querySelector('input[name="size"]:checked')?.value || '-';
    const holder = document.querySelector('input[name="holder_type"]:checked')?.value || '-';
    const finish = document.querySelector('input[name="finish"]:checked')?.value || '-';
    const quantity = document.querySelector('input[name="quantity"]:checked')?.value || '-';

    document.getElementById('preview-size').textContent = size;
    document.getElementById('preview-holder').textContent = holder;
    document.getElementById('preview-finish').textContent = finish;
    document.getElementById('preview-designs').textContent = uploadedFiles.length;
    document.getElementById('preview-quantity').textContent = quantity;

    updatePricePreview();
  }

  // Form submission
  document.getElementById('bigdawgs-form').addEventListener('submit', (e) => {
    e.preventDefault();

    const size = document.querySelector('input[name="size"]:checked')?.value;
    const holder = document.querySelector('input[name="holder_type"]:checked')?.value;
    const finish = document.querySelector('input[name="finish"]:checked')?.value;
    const quantity = document.querySelector('input[name="quantity"]:checked')?.value;

    // Find the variant ID based on selections
    const variantMap = {
      'standard': {
        'One Touch': {
          'Regular': '44159751282874',
          'Holo': '44159751315642',
          'Cracked Ice': '44159751348410'
        },
        'Toploader': {
          'Regular': '44159751381178',
          'Holo': '44159751413946',
          'Cracked Ice': '44159751446714'
        }
      },
      'wide': {
        'One Touch': {
          'Regular': '44159751479482',
          'Holo': '44159751512250',
          'Cracked Ice': '44159751545018'
        },
        'Toploader': {
          'Regular': '44159751577786',
          'Holo': '44159751610554',
          'Cracked Ice': '44159751643322'
        }
      }
    };

    const variantId = variantMap[size]?.[holder]?.[finish] || '';
    document.getElementById('variant-id').value = variantId;
    document.getElementById('form-size').value = size;
    document.getElementById('form-holder').value = holder;
    document.getElementById('form-finish').value = finish;
    document.getElementById('form-qty-per-design').value = quantity;
    document.getElementById('form-num-designs').value = uploadedFiles.length;
    document.getElementById('form-files').value = uploadedFiles.map(f => f.name).join(', ');

    // Calculate total quantity (per design qty × number of designs)
    const totalQuantity = parseInt(quantity) * uploadedFiles.length;
    document.getElementById('form-quantity').value = totalQuantity;

    var submitBtn = document.getElementById('submit-btn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="loading-spinner"></span>Adding to Cart...';

    setTimeout(function() {
      e.target.submit();
    }, 400);
  }
</script>

