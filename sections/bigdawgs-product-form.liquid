{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Top Loader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), Wide size,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 30px;
    display: none;
  }

  .sticky-summary.visible {
    display: block;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-label {
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-step {
    display: none;
    animation: slideIn 0.3s ease-out;
  }

  .form-step.active {
    display: block;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-label {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
    font-size: 14px;
    color: var(--bd-white);
  }

  .form-label.required::after {
    content: ' *';
    color: var(--bd-red);
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .option-button {
    padding: 16px;
    border: 2px solid var(--bd-gray);
    background-color: transparent;
    color: var(--bd-white);
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease;
    text-align: center;
  }

  .option-button:hover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .option-button.selected {
    background-color: var(--bd-red);
    border-color: var(--bd-red);
    color: var(--bd-white);
  }

  .price-tiers {
    margin-top: 16px;
  }

  .tier-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .tier-table thead {
    background-color: var(--bd-dark);
    border-bottom: 2px solid var(--bd-gray);
  }

  .tier-table th {
    padding: 12px 8px;
    text-align: left;
    font-weight: 600;
    color: var(--bd-white);
  }

  .tier-table td {
    padding: 12px 8px;
    border-bottom: 1px solid var(--bd-gray);
    color: var(--bd-light);
  }

  .tier-table tr:hover {
    background-color: rgba(204, 0, 0, 0.05);
  }

  .tier-row.best-value {
    background-color: rgba(212, 160, 23, 0.1);
    border-left: 3px solid var(--bd-gold);
  }

  .best-value-badge {
    display: inline-block;
    background-color: var(--bd-gold);
    color: var(--bd-black);
    padding: 4px 8px;
    border-radius: 3px;
    font-weight: 600;
    font-size: 11px;
    margin-right: 8px;
  }

  .quantity-selector {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 12px;
  }

  .quantity-input {
    flex: 1;
    padding: 12px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    color: var(--bd-white);
    border-radius: 4px;
    font-size: 14px;
  }

  .quantity-input:focus {
    outline: none;
    border-color: var(--bd-red);
    box-shadow: 0 0 0 2px rgba(204, 0, 0, 0.2);
  }

  .quantity-buttons {
    display: flex;
    gap: 4px;
  }

  .qty-btn {
    padding: 10px 12px;
    background-color: var(--bd-gray);
    border: none;
    color: var(--bd-white);
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .qty-btn:hover {
    background-color: var(--bd-red);
  }

  .file-upload-area {
    border: 2px dashed var(--bd-gray);
    border-radius: 8px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    background-color: rgba(255, 255, 255, 0.02);
  }

  .file-upload-area.dragover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .file-upload-area.has-file {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.05);
  }

  .upload-icon {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .upload-text {
    font-size: 14px;
    color: var(--bd-light);
    margin-bottom: 4px;
  }

  .upload-subtext {
    font-size: 12px;
    color: var(--bd-gray);
  }

  .file-preview {
    margin-top: 16px;
    padding: 12px;
    background-color: var(--bd-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .preview-image {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
  }

  .preview-info {
    flex: 1;
    text-align: left;
  }

  .preview-name {
    font-weight: 600;
    color: var(--bd-white);
    font-size: 13px;
    margin-bottom: 4px;
  }

  .preview-size {
    font-size: 12px;
    color: var(--bd-gray);
  }

  .preview-remove {
    background-color: rgba(204, 0, 0, 0.2);
    color: var(--bd-red);
    border: none;
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .preview-remove:hover {
    background-color: var(--bd-red);
    color: var(--bd-white);
  }

  .order-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-row.total {
    border-top: 1px solid var(--bd-gray);
    padding-top: 12px;
    margin-top: 12px;
    font-size: 16px;
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
  }

  .btn {
    flex: 1;
    padding: 14px 24px;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .btn-primary {
    background-color: var(--bd-red);
    color: var(--bd-white);
  }

  .btn-primary:hover:not(:disabled) {
    background-color: var(--bd-red-dark);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--bd-white);
    border: 2px solid var(--bd-red);
  }

  .btn-secondary:hover:not(:disabled) {
    background-color: rgba(204, 0, 0, 0.1);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .step-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--bd-white);
  }

  .step-description {
    font-size: 14px;
    color: var(--bd-light);
    margin-bottom: 24px;
  }

  .error-message {
    background-color: rgba(204, 0, 0, 0.1);
    border: 1px solid var(--bd-red);
    color: #ff6b6b;
    padding: 12px;
    border-radius: 4px;
    font-size: 13px;
    margin-bottom: 16px;
  }

  .success-message {
    background-color: rgba(0, 200, 0, 0.1);
    border: 1px solid #00c800;
    color: #5fdb5f;
    padding: 12px;
    border-radius: 4px;
    font-size: 13px;
    margin-bottom: 16px;
  }

  @media (max-width: 600px) {
    .bigdawgs-form-container {
      padding: 24px 16px;
    }

    .option-grid {
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    }

    .form-actions {
      flex-direction: column;
    }

    .tier-table {
      font-size: 12px;
    }

    .tier-table th,
    .tier-table td {
      padding: 8px 4px;
    }
  }
</style>

<div class="bigdawgs-form-container">
  <div class="form-progress-bar">
    <div class="progress-dot active" data-step="1"></div>
    <div class="progress-dot" data-step="2"></div>
    <div class="progress-dot" data-step="3"></div>
    <div class="progress-dot" data-step="4"></div>
    <div class="progress-dot" data-step="5"></div>
  </div>

  <div class="sticky-summary" id="summaryBox">
    <div class="summary-item">
      <span class="summary-label">Holder Type:</span>
      <span id="summaryHolderType">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Size:</span>
      <span id="summarySize">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Finish:</span>
      <span id="summaryFinish">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Quantity:</span>
      <span id="summaryQuantity">-</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Unit Price:</span>
      <span id="summaryUnitPrice">-</span>
    </div>
    <div class="summary-item total">
      <span>Total:</span>
      <span id="summaryTotal">-</span>
    </div>
  </div>

  <form id="stickerForm">
    <div class="form-step active" data-step="1">
      <div class="step-title">Select Holder Type</div>
      <div class="step-description">What type of card holder are your stickers for?</div>
      
      <div class="form-group">
        <div class="option-grid">
          <button type="button" class="option-button" data-option="OneTouch" data-value="OneTouch">
            <span>🎬</span><br>One Touch
          </button>
          <button type="button" class="option-button" data-option="TopLoader" data-value="TopLoader">
            <span>📦</span><br>Top Loader
          </button>
          <button type="button" class="option-button" data-option="PSA" data-value="PSA">
            <span>🏆</span><br>PSA Case
          </button>
          <button type="button" class="option-button" data-option="Custom" data-value="Custom">
            <span>✨</span><br>Custom Size
          </button>
        </div>
      </div>
    </div>

    <div class="form-step" data-step="2">
      <div class="step-title">Select Size</div>
      <div class="step-description">Choose the size of your stickers</div>
      
      <div class="form-group">
        <div class="option-grid">
          <button type="button" class="option-button" data-option="Small" data-value="Small">
            Small
          </button>
          <button type="button" class="option-button" data-option="Medium" data-value="Medium">
            Medium
          </button>
          <button type="button" class="option-button" data-option="Large" data-value="Large">
            Large
          </button>
        </div>
      </div>
    </div>

    <div class="form-step" data-step="3">
      <div class="step-title">Select Finish</div>
      <div class="step-description">How would you like your stickers to look?</div>
      
      <div class="form-group">
        <div class="option-grid">
          <button type="button" class="option-button" data-option="Regular" data-value="Regular">
            Regular
          </button>
          <button type="button" class="option-button" data-option="Holographic" data-value="Holographic">
            Holographic
          </button>
          <button type="button" class="option-button" data-option="CrackedIce" data-value="CrackedIce">
            Cracked Ice
          </button>
        </div>
      </div>
    </div>

    <div class="form-step" data-step="4">
      <div class="step-title">Choose Quantity & Price</div>
      <div class="step-description">Select your quantity for the best price</div>
      
      <div id="priceContainer" class="price-tiers">
        <!-- Price tiers will be populated by JavaScript -->
      </div>

      <div class="quantity-selector">
        <label class="form-label">Custom Quantity</label>
        <div style="display: flex; gap: 8px; width: 100%;">
          <div class="quantity-buttons">
            <button type="button" class="qty-btn" id="qtyMinus">−</button>
            <input type="number" id="customQty" class="quantity-input" placeholder="Enter quantity" value="100" min="10">
            <button type="button" class="qty-btn" id="qtyPlus">+</button>
          </div>
        </div>
      </div>

      <div style="margin-top: 12px; color: var(--bd-light); font-size: 13px;">
        Custom quantities: <span id="customPriceDisplay">$0.00</span> total
      </div>
    </div>

    <div class="form-step" data-step="5">
      <div class="step-title">Upload Your Artwork</div>
      <div class="step-description">Drag and drop your image or click to browse</div>
      
      <div class="form-group">
        <div id="fileUploadArea" class="file-upload-area">
          <div class="upload-icon">📁</div>
          <div class="upload-text">Drop your image here or click to select</div>
          <div class="upload-subtext">PNG, JPG, or GIF (max 20MB)</div>
          <input type="file" id="fileInput" style="display: none;" accept="image/*">
        </div>
        <div id="filePreview" style="display: none;">
          <div class="file-preview">
            <img id="previewImage" class="preview-image" src="" alt="Preview">
            <div class="preview-info">
              <div class="preview-name" id="previewName"></div>
              <div class="preview-size" id="previewSize"></div>
            </div>
            <button type="button" id="removeFileBtn" class="preview-remove">Remove</button>
          </div>
        </div>
      </div>
    </div>

    <div id="orderSummary" class="order-summary" style="display: none;">
      <div class="summary-row">
        <span>Holder Type:</span>
        <span id="finalHolderType">-</span>
      </div>
      <div class="summary-row">
        <span>Size:</span>
        <span id="finalSize">-</span>
      </div>
      <div class="summary-row">
        <span>Finish:</span>
        <span id="finalFinish">-</span>
      </div>
      <div class="summary-row">
        <span>Quantity:</span>
        <span id="finalQuantity">-</span>
      </div>
      <div class="summary-row">
        <span>Unit Price:</span>
        <span id="finalUnitPrice">-</span>
      </div>
      <div class="summary-row total">
        <span>Total Price:</span>
        <span id="finalTotal">-</span>
      </div>
      <div class="summary-row" style="margin-top: 12px; font-size: 12px; color: var(--bd-gray);">
        <span>Artwork File:</span>
        <span id="finalFile">-</span>
      </div>
    </div>

    <div class="form-actions">
      <button type="button" id="prevBtn" class="btn btn-secondary" style="display: none;">
        ← Back
      </button>
      <button type="button" id="nextBtn" class="btn btn-primary">
        Next →
      </button>
    </div>
  </form>
</div>

