{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Toploader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), sizes Small/Medium/Large,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 30px;
    display: none;
  }

  .sticky-summary.visible {
    display: block;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-label {
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-step {
    display: none;
    animation: slideIn 0.4s ease;
  }

  .form-step.active {
    display: block;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .form-heading {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--bd-white);
  }

  .form-subheading {
    font-size: 15px;
    color: #999;
    margin-bottom: 32px;
    line-height: 1.5;
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }

  .option-card {
    border: 2px solid var(--bd-gray);
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    background-color: var(--bd-dark);
    transition: all 0.25s ease;
    position: relative;
  }

  .option-card:hover {
    border-color: var(--bd-red);
    transform: translateY(-4px);
  }

  .option-card.selected {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
    box-shadow: 0 0 20px rgba(204, 0, 0, 0.3);
  }

  .option-card.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .option-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--bd-white);
    margin-bottom: 6px;
  }

  .option-desc {
    font-size: 12px;
    color: #888;
    line-height: 1.4;
  }

  .option-price {
    font-size: 15px;
    font-weight: 700;
    color: var(--bd-gold);
    margin-top: 10px;
  }

  .form-group {
    margin-bottom: 30px;
  }

  .form-label {
    display: block;
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 10px;
    color: var(--bd-white);
  }

  .upload-zone {
    border: 2px dashed var(--bd-gray);
    border-radius: 10px;
    padding: 30px 20px;
    text-align: center;
    cursor: pointer;
    background-color: var(--bd-dark);
    transition: all 0.3s ease;
    position: relative;
    margin-bottom: 15px;
  }

  .upload-zone:hover,
  .upload-zone.drag-over {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.05);
  }

  .upload-zone.has-file {
    border-color: var(--bd-gold);
    background-color: rgba(212, 160, 23, 0.08);
  }

  .file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .upload-icon {
    font-size: 2.5rem;
    margin-bottom: 10px;
    display: block;
  }

  .upload-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--bd-white);
    margin-bottom: 6px;
  }

  .upload-hint {
    font-size: 13px;
    color: #888;
    margin-bottom: 8px;
  }

  .upload-formats {
    font-size: 11px;
    color: #555;
  }

  .upload-preview {
    display: none;
    background-color: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 14px;
    margin-top: 12px;
    font-size: 13px;
    color: var(--bd-gold);
  }

  .upload-preview.show {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .preview-file-info {
    flex: 1;
    text-align: left;
  }

  .preview-file-name {
    color: var(--bd-white);
    font-weight: 600;
    display: block;
    margin-bottom: 3px;
  }

  .preview-file-size {
    color: #666;
    font-size: 11px;
  }

  .remove-file-btn {
    background: none;
    border: none;
    color: #cc6666;
    cursor: pointer;
    font-size: 20px;
    padding: 0;
    flex-shrink: 0;
  }

  .remove-file-btn:hover {
    color: #ff6666;
  }

  .or-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
    color: #555;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .or-divider::before,
  .or-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: #333;
  }

  .text-input {
    width: 100%;
    padding: 12px 14px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    color: var(--bd-white);
    font-size: 14px;
    font-family: inherit;
    transition: border-color 0.3s ease;
  }

  .text-input:focus {
    outline: none;
    border-color: var(--bd-red);
  }

  .text-input::placeholder {
    color: #555;
  }

  textarea.text-input {
    min-height: 100px;
    resize: vertical;
  }

  .form-help {
    font-size: 12px;
    color: #666;
    margin-top: 6px;
  }

  .button-group {
    display: flex;
    gap: 12px;
    margin-top: 40px;
  }

  .btn {
    padding: 15px 24px;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.25s ease;
    flex: 1;
  }

  .btn-primary {
    background-color: var(--bd-red);
    color: var(--bd-white);
  }

  .btn-primary:hover:not(:disabled) {
    background-color: var(--bd-red-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(204, 0, 0, 0.4);
  }

  .btn-primary:disabled {
    background-color: var(--bd-gray);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    flex: 0 0 120px;
    background-color: var(--bd-dark);
    color: var(--bd-white);
    border: 1px solid var(--bd-gray);
  }

  .btn-secondary:hover {
    border-color: var(--bd-red);
    color: var(--bd-red);
  }

  .spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid var(--bd-gold);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 8px;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    .form-heading {
      font-size: 22px;
    }

    .option-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .button-group {
      flex-direction: column;
    }

    .btn-secondary {
      flex: 1;
    }
  }
</style>

<div class="bigdawgs-form-container">
  <div class="form-progress-bar">
    <div class="progress-dot active" data-step="1"></div>
    <div class="progress-dot" data-step="2"></div>
    <div class="progress-dot" data-step="3"></div>
  </div>

  <div class="sticky-summary" id="form-summary">
    <div class="summary-item">
      <span class="summary-label">Size:</span>
      <span id="summary-size">—</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Finish:</span>
      <span id="summary-finish">—</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Price:</span>
      <span id="summary-price" style="color: var(--bd-gold); font-weight: 700;">—</span>
    </div>
  </div>

  <form id="product-form" action="/cart/add" method="post">

    <!-- STEP 1: SIZE -->
    <div class="form-step active" data-step="1">
      <h2 class="form-heading">Select Size</h2>
      <p class="form-subheading">Choose your preferred dimensions. Sizes shown are print area — perfect for laptops, water bottles, packaging, and more.</p>

      <div class="option-grid" id="size-options">
        <div class="option-card" data-option="size" data-value="1&quot; x 1&quot;">
          <div class="option-label">1&quot; × 1&quot;</div>
          <div class="option-desc">Micro</div>
        </div>
        <div class="option-card" data-option="size" data-value="2&quot; x 2&quot;">
          <div class="option-label">2&quot; × 2&quot;</div>
          <div class="option-desc">Small</div>
        </div>
        <div class="option-card" data-option="size" data-value="3&quot; x 3&quot;">
          <div class="option-label">3&quot; × 3&quot;</div>
          <div class="option-desc">Medium</div>
        </div>
        <div class="option-card" data-option="size" data-value="4&quot; x 4&quot;">
          <div class="option-label">4&quot; × 4&quot;</div>
          <div class="option-desc">Large</div>
        </div>
        <div class="option-card" data-option="size" data-value="5&quot; x 5&quot;">
          <div class="option-label">5&quot; × 5&quot;</div>
          <div class="option-desc">XL</div>
        </div>
      </div>

      <div class="button-group">
        <button type="button" class="btn btn-primary" id="step1-next">Continue</button>
      </div>
    </div>

    <!-- STEP 2: FINISH -->
    <div class="form-step" data-step="2">
      <h2 class="form-heading">Select Finish</h2>
      <p class="form-subheading">Choose the look and feel of your stickers — price shown reflects your selected size.</p>

      <div class="option-grid" id="finish-options">
        <div class="option-card" data-option="finish" data-value="Regular">
          <div class="option-label">Regular</div>
          <div class="option-desc">Clean matte vinyl — professional and sharp</div>
          <div class="option-price" id="price-regular">—</div>
        </div>
        <div class="option-card" data-option="finish" data-value="Holographic">
          <div class="option-label">Holographic</div>
          <div class="option-desc">Full rainbow color-shift — impossible to ignore</div>
          <div class="option-price" id="price-holo">—</div>
        </div>
        <div class="option-card" data-option="finish" data-value="Cracked Ice">
          <div class="option-label">Cracked Ice</div>
          <div class="option-desc">Unique fractured-crystal pattern — bold and distinct</div>
          <div class="option-price" id="price-cracked">—</div>
        </div>
      </div>

      <div class="button-group">
        <button type="button" class="btn btn-secondary" id="step2-back">Back</button>
        <button type="button" class="btn btn-primary" id="step2-next">Continue</button>
      </div>
    </div>

    <!-- STEP 3: ARTWORK & DETAILS -->
    <div class="form-step" data-step="3">
      <h2 class="form-heading">Upload Artwork</h2>
      <p class="form-subheading">Share your design file or artwork link — we'll review and confirm before printing.</p>

      <div class="form-group">
        <label class="form-label">Your Artwork</label>
        <div class="upload-zone" id="upload-zone" data-option="artwork">
          <input type="file" class="file-input" id="file-input" accept="image/*,.pdf,.ai,.psd,.eps">
          <span class="upload-icon" id="upload-icon">📎</span>
          <p class="upload-title" id="upload-title">Upload Your Artwork</p>
          <p class="upload-hint" id="upload-hint">Drag &amp; drop or tap to browse — mobile camera supported</p>
          <p class="upload-formats">PNG, JPG, PDF, AI, PSD · Any size · 300 DPI+ preferred</p>
        </div>
        <div class="upload-preview" id="upload-preview">
          <div class="preview-file-info">
            <span class="preview-file-name" id="preview-file-name">—</span>
            <span class="preview-file-size" id="preview-file-size">—</span>
          </div>
          <button type="button" class="remove-file-btn" id="remove-file-btn" title="Remove file">✕</button>
        </div>
        <div class="or-divider">or</div>
        <input type="text" class="text-input" id="artwork-url" placeholder="Paste a Google Drive, Dropbox, or file share link here">
        <p class="form-help">We'll review your file and confirm placement, colors, and timing before we print.</p>
      </div>

      <div class="form-group">
        <label class="form-label" for="notes">Order Notes <span style="font-weight: 400; color: #666;">(optional)</span></label>
        <textarea class="text-input" id="notes" name="properties[Order Notes]" placeholder="Colors, placement, special instructions..."></textarea>
      </div>

      <!-- Hidden form fields for cart submission -->
      <input type="hidden" name="id" id="variant-id" value="">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="properties[Size]" id="prop-size" value="">
      <input type="hidden" name="properties[Finish]" id="prop-finish" value="">
      <input type="hidden" name="properties[Artwork]" id="prop-artwork" value="">

      <div class="button-group">
        <button type="button" class="btn btn-secondary" id="step3-back">Back</button>
        <button type="submit" class="btn btn-primary" id="submit-btn">Add to Cart</button>
      </div>
    </div>

  </form>
</div>

<script>
(function() {
  // TESTING MODE — set to false to require artwork before submitting
  const TESTING_MODE = true;

  const variants = {{ product.variants | json }} || [];
  const state = { size: null, finish: null, variantId: null, price: null, artworkFile: null };

  // Find a variant matching size and finish
  function findVariant(size, finish) {
    return variants.find(v => v.option1 === size && v.option2 === finish) || null;
  }

  // Get price for a specific size/finish combo
  function getPriceForSizeFinish(size, finish) {
    const v = findVariant(size, finish);
    return v ? (v.price / 100).toFixed(2) : null;
  }

  // Update all finish prices based on selected size
  function updateFinishPrices() {
    const finishes = [
      { name: 'Regular',       priceEl: 'price-regular',  value: 'Regular' },
      { name: 'Holographic',   priceEl: 'price-holo',     value: 'Holographic' },
      { name: 'Cracked Ice',   priceEl: 'price-cracked',  value: 'Cracked Ice' }
    ];

    finishes.forEach(function(finish) {
      const price = getPriceForSizeFinish(state.size, finish.value);
      const priceEl = document.getElementById(finish.priceEl);
      const card = document.querySelector('[data-option="finish"][data-value="' + finish.value + '"]');

      if (priceEl) {
        priceEl.textContent = price ? '$' + price : 'Unavailable';
        priceEl.style.color = price ? 'var(--bd-gold)' : '#666';
      }

      if (card) {
        if (!price) {
          card.classList.add('disabled');
        } else {
          card.classList.remove('disabled');
        }
      }
    });

    // Clear finish selection if previously selected finish is now unavailable
    if (state.finish && !getPriceForSizeFinish(state.size, state.finish)) {
      state.finish = null;
      state.variantId = null;
      state.price = null;
      document.querySelectorAll('[data-option="finish"]').forEach(card => card.classList.remove('selected'));
    }
  }

  // Navigate to a specific step
  function goToStep(step) {
    // Hide all steps
    document.querySelectorAll('.form-step').forEach(el => el.classList.remove('active'));
    // Show target step
    document.querySelector('.form-step[data-step="' + step + '"]').classList.add('active');

    // Update progress dots
    document.querySelectorAll('.progress-dot').forEach((dot, index) => {
      dot.classList.remove('active', 'completed');
      const dotStep = index + 1;
      if (dotStep === step) {
        dot.classList.add('active');
      } else if (dotStep < step) {
        dot.classList.add('completed');
      }
    });

    // Show summary if not on step 1
    const summary = document.getElementById('form-summary');
    if (step > 1) {
      summary.classList.add('visible');
    } else {
      summary.classList.remove('visible');
    }

    // Scroll to top
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Update the sticky summary display
  function updateSummary() {
    document.getElementById('summary-size').textContent = state.size || '—';
    document.getElementById('summary-finish').textContent = state.finish || '—';
    if (state.price) {
      document.getElementById('summary-price').textContent = '$' + state.price;
    }
  }

  // Handle size selection
  document.querySelectorAll('[data-option="size"]').forEach(card => {
    card.addEventListener('click', function() {
      document.querySelectorAll('[data-option="size"]').forEach(c => c.classList.remove('selected'));
      this.classList.add('selected');
      state.size = this.dataset.value;
      updateSummary();
    });
  });

  // Handle finish selection
  document.querySelectorAll('[data-option="finish"]').forEach(card => {
    card.addEventListener('click', function() {
      document.querySelectorAll('[data-option="finish"]').forEach(c => c.classList.remove('selected'));
      this.classList.add('selected');
      state.finish = this.dataset.value;
      const v = findVariant(state.size, state.finish);
      if (v) {
        state.variantId = v.id;
        state.price = (v.price / 100).toFixed(2);
      }
      updateSummary();
    });
  });

  // Step 1: Next button
  document.getElementById('step1-next').addEventListener('click', function() {
    if (!state.size) {
      alert('Please select a size.');
      return;
    }
    updateFinishPrices();
    goToStep(2);
  });

  // Step 2: Back button
  document.getElementById('step2-back').addEventListener('click', function() {
    goToStep(1);
  });

  // Step 2: Next button
  document.getElementById('step2-next').addEventListener('click', function() {
    if (!state.finish) {
      alert('Please select a finish.');
      return;
    }
    goToStep(3);
  });

  // Step 3: Back button
  document.getElementById('step3-back').addEventListener('click', function() {
    goToStep(2);
  });

  // File upload handling
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input');
  const uploadPreview = document.getElementById('upload-preview');
  const removeFileBtn = document.getElementById('remove-file-btn');

  uploadZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    uploadZone.classList.add('drag-over');
  });

  uploadZone.addEventListener('dragleave', function() {
    uploadZone.classList.remove('drag-over');
  });

  uploadZone.addEventListener('drop', function(e) {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    if (e.dataTransfer.files[0]) {
      handleFileSelect(e.dataTransfer.files[0]);
    }
  });

  fileInput.addEventListener('change', function() {
    if (this.files[0]) {
      handleFileSelect(this.files[0]);
    }
  });

  removeFileBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    state.artworkFile = null;
    uploadZone.classList.remove('has-file');
    uploadPreview.classList.remove('show');
    fileInput.value = '';
    document.getElementById('upload-title').textContent = 'Upload Your Artwork';
    document.getElementById('upload-hint').textContent = 'Drag & drop or tap to browse — mobile camera supported';
  });

  function handleFileSelect(file) {
    state.artworkFile = file.name;
    uploadZone.classList.add('has-file');
    document.getElementById('preview-file-name').textContent = file.name;
    document.getElementById('preview-file-size').textContent = formatBytes(file.size);
    document.getElementById('upload-title').textContent = '✓ Ready to print';
    document.getElementById('upload-hint').textContent = file.name;
    uploadPreview.classList.add('show');
  }

  function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }

  // Form submission
  document.getElementById('product-form').addEventListener('submit', function(e) {
    e.preventDefault();

    // Validate size and finish
    if (!state.size || !state.finish) {
      alert('Please complete all steps before submitting.');
      return;
    }

    // Validate variant exists
    if (!state.variantId) {
      alert('The ' + state.size + ' / ' + state.finish + ' combination isn\'t currently available. Please choose a different size or finish.');
      return;
    }

    // Get artwork
    const artworkUrl = document.getElementById('artwork-url').value.trim();
    if (!TESTING_MODE && !state.artworkFile && !artworkUrl) {
      alert('Please upload your artwork or paste a link.');
      return;
    }

    // Set hidden fields
    document.getElementById('variant-id').value = state.variantId;
    document.getElementById('prop-size').value = state.size;
    document.getElementById('prop-finish').value = state.finish;
    document.getElementById('prop-artwork').value = state.artworkFile
      ? 'File: ' + state.artworkFile + ' (will be emailed)'
      : artworkUrl;

    // Submit
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span>Adding to Cart...';
    setTimeout(() => { e.target.submit(); }, 400);
  });
})();
</script>

{% schema %}
{
  "name": "BigDawgs Product Form",
  "settings": [
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product Handle",
      "default": "custom-card-stickers"
    }
  ]
}
{% endschema %}