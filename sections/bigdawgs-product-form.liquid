{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Toploader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), sizes Small/Medium/Large,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);