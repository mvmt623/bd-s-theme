let formState = {
  currentStep: 1,
  holderType: null,
  size: null,
  finish: null,
  quantity: 100,
  file: null
};

const form = document.getElementById('stickerForm');
const steps = document.querySelectorAll('.form-step');
const buttons = document.querySelectorAll('.option-button');
const nextBtn = document.getElementById('nextBtn');
const prevBtn = document.getElementById('prevBtn');
const progressDots = document.querySelectorAll('.progress-dot');
const priceContainer = document.getElementById('priceContainer');
const customQty = document.getElementById('customQty');
const qtyMinus = document.getElementById('qtyMinus');
const qtyPlus = document.getElementById('qtyPlus');
const fileUploadArea = document.getElementById('fileUploadArea');
const fileInput = document.getElementById('fileInput');
const filePreview = document.getElementById('filePreview');
const removeFileBtn = document.getElementById('removeFileBtn');
const summaryBox = document.getElementById('summaryBox');
const orderSummary = document.getElementById('orderSummary');

function updateProgressBar() {
  progressDots.forEach((dot, index) => {
    dot.classList.remove('active', 'completed');
    if (index + 1 === formState.currentStep) {
      dot.classList.add('active');
    } else if (index + 1 < formState.currentStep) {
      dot.classList.add('completed');
    }
  });
}

function showStep(step) {
  steps.forEach(s => s.classList.remove('active'));
  steps[step - 1].classList.add('active');
  
  prevBtn.style.display = step > 1 ? 'flex' : 'none';
  nextBtn.textContent = step === 5 ? 'Add to Cart' : 'Next →';
  nextBtn.disabled = !isStepValid(step);
  
  if (step > 1) {
    summaryBox.classList.add('visible');
  } else {
    summaryBox.classList.remove('visible');
  }
  
  if (step === 5) {
    updateOrderSummary();
    orderSummary.style.display = 'block';
  } else {
    orderSummary.style.display = 'none';
  }
  
  updateProgressBar();
}

function isStepValid(step) {
  switch(step) {
    case 1: return formState.holderType !== null;
    case 2: return formState.size !== null;
    case 3: return formState.finish !== null;
    case 4: return formState.quantity > 0;
    case 5: return formState.file !== null;
    default: return false;
  }
}

function selectOption(e) {
  if (e.target.classList.contains('option-button')) {
    const button = e.target.closest('.option-button');
    const step = document.querySelector('.form-step.active');
    const buttons = step.querySelectorAll('.option-button');
    
    buttons.forEach(b => b.classList.remove('selected'));
    button.classList.add('selected');
    
    const value = button.dataset.value;
    const step_num = parseInt(step.dataset.step);
    
    switch(step_num) {
      case 1:
        formState.holderType = value;
        break;
      case 2:
        formState.size = value;
        break;
      case 3:
        formState.finish = value;
        renderPriceTiers();
        break;
    }
    
    updateSummary();
    nextBtn.disabled = !isStepValid(formState.currentStep);
  }
}

function renderPriceTiers() {
  if (!formState.holderType || !formState.size || !formState.finish) return;
  
  const tiers = PRICING_DATA[formState.holderType][formState.size][formState.finish];
  let html = '<table class="tier-table"><thead><tr><th>Quantity</th><th>Unit Price</th><th>Total</th></tr></thead><tbody>';
  
  tiers.forEach(tier => {
    const total = (tier.qty * tier.price).toFixed(2);
    const rowClass = tier.bestValue ? 'tier-row best-value' : 'tier-row';
    const badge = tier.bestValue ? '<span class="best-value-badge">Best Value</span>' : '';
    html += `<tr class="${rowClass}" data-tier-qty="${tier.qty}" data-tier-price="${tier.price}">
      <td>${badge}${tier.qty}</td>
      <td>$${tier.price.toFixed(2)}</td>
      <td>$${total}</td>
    </tr>`;
  });
  
  html += '</tbody></table>';
  priceContainer.innerHTML = html;
  
  const rows = priceContainer.querySelectorAll('tr[data-tier-qty]');
  rows.forEach(row => {
    row.style.cursor = 'pointer';
    row.addEventListener('click', () => selectTier(row));
  });
}

function selectTier(row) {
  const rows = priceContainer.querySelectorAll('tr[data-tier-qty]');
  rows.forEach(r => r.style.backgroundColor = '');
  row.style.backgroundColor = 'rgba(204, 0, 0, 0.2)';
  
  formState.quantity = parseInt(row.dataset.tierQty);
  customQty.value = formState.quantity;
  updateCustomPriceDisplay();
  updateSummary();
}

function updateCustomPriceDisplay() {
  const tiers = PRICING_DATA[formState.holderType][formState.size][formState.finish];
  const qty = parseInt(customQty.value);
  let price = tiers[tiers.length - 1].price;
  
  for (let i = tiers.length - 1; i >= 0; i--) {
    if (qty >= tiers[i].qty) {
      price = tiers[i].price;
      break;
    }
  }
  
  const total = (qty * price).toFixed(2);
  formState.quantity = qty;
  document.getElementById('customPriceDisplay').textContent = '$' + total;
  updateSummary();
}

function updateSummary() {
  if (formState.holderType) {
    document.getElementById('summaryHolderType').textContent = formState.holderType;
  }
  if (formState.size) {
    document.getElementById('summarySize').textContent = formState.size;
  }
  if (formState.finish) {
    document.getElementById('summaryFinish').textContent = formState.finish;
  }
  if (formState.quantity) {
    document.getElementById('summaryQuantity').textContent = formState.quantity;
    const unitPrice = getPriceForQuantity(formState.quantity);
    document.getElementById('summaryUnitPrice').textContent = '$' + unitPrice.toFixed(2);
    document.getElementById('summaryTotal').textContent = '$' + (formState.quantity * unitPrice).toFixed(2);
  }
}

function getPriceForQuantity(qty) {
  if (!formState.holderType || !formState.size || !formState.finish) return 0;
  const tiers = PRICING_DATA[formState.holderType][formState.size][formState.finish];
  for (let i = tiers.length - 1; i >= 0; i--) {
    if (qty >= tiers[i].qty) {
      return tiers[i].price;
    }
  }
  return tiers[0].price;
}

function updateOrderSummary() {
  const unitPrice = getPriceForQuantity(formState.quantity);
  const total = (formState.quantity * unitPrice).toFixed(2);
  
  document.getElementById('finalHolderType').textContent = formState.holderType;
  document.getElementById('finalSize').textContent = formState.size;
  document.getElementById('finalFinish').textContent = formState.finish;
  document.getElementById('finalQuantity').textContent = formState.quantity;
  document.getElementById('finalUnitPrice').textContent = '$' + unitPrice.toFixed(2);
  document.getElementById('finalTotal').textContent = '$' + total;
  document.getElementById('finalFile').textContent = formState.file ? formState.file.name : 'No file selected';
}

function handleFileUpload(file) {
  if (!file.type.startsWith('image/')) {
    alert('Please select an image file');
    return;
  }
  
  if (file.size > 20 * 1024 * 1024) {
    alert('File size must be less than 20MB');
    return;
  }
  
  formState.file = file;
  const reader = new FileReader();
  reader.onload = (e) => {
    document.getElementById('previewImage').src = e.target.result;
    document.getElementById('previewName').textContent = file.name;
    document.getElementById('previewSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
    fileUploadArea.style.display = 'none';
    filePreview.style.display = 'block';
    nextBtn.disabled = !isStepValid(formState.currentStep);
  };
  reader.readAsDataURL(file);
}

function setupEventListeners() {
  buttons.forEach(btn => {
    btn.addEventListener('click', selectOption);
  });
  
  nextBtn.addEventListener('click', () => {
    if (formState.currentStep < 5) {
      formState.currentStep++;
      showStep(formState.currentStep);
    } else {
      addToCart();
    }
  });
  
  prevBtn.addEventListener('click', () => {
    if (formState.currentStep > 1) {
      formState.currentStep--;
      showStep(formState.currentStep);
    }
  });
  
  customQty.addEventListener('change', updateCustomPriceDisplay);
  customQty.addEventListener('input', updateCustomPriceDisplay);
  
  qtyMinus.addEventListener('click', (e) => {
    e.preventDefault();
    const qty = parseInt(customQty.value) || 100;
    customQty.value = Math.max(10, qty - 50);
    updateCustomPriceDisplay();
  });
  
  qtyPlus.addEventListener('click', (e) => {
    e.preventDefault();
    const qty = parseInt(customQty.value) || 100;
    customQty.value = qty + 50;
    updateCustomPriceDisplay();
  });
  
  fileUploadArea.addEventListener('click', () => fileInput.click());
  
  fileUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    fileUploadArea.classList.add('dragover');
  });
  
  fileUploadArea.addEventListener('dragleave', () => {
    fileUploadArea.classList.remove('dragover');
  });
  
  fileUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    fileUploadArea.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    handleFileUpload(file);
  });
  
  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) handleFileUpload(file);
  });
  
  removeFileBtn.addEventListener('click', () => {
    formState.file = null;
    fileInput.value = '';
    fileUploadArea.style.display = 'block';
    filePreview.style.display = 'none';
    nextBtn.disabled = !isStepValid(formState.currentStep);
  });
}

function addToCart() {
  if (!isStepValid(5)) {
    alert('Please complete all steps before adding to cart');
    return;
  }
  
  const unitPrice = getPriceForQuantity(formState.quantity);
  const matchingPrice = unitPrice.toFixed(2);
  
  const productHandle = 'custom-card-stickers';
  const variantId = findVariantByPrice(matchingPrice);
  
  if (!variantId) {
    alert('Unable to find matching variant. Please contact support.');
    return;
  }
  
  const formData = new FormData();
  formData.append('id', variantId);
  formData.append('quantity', formState.quantity);
  
  const fileField = document.getElementById('fileInput');
  if (fileField.files[0]) {
    formData.append('properties[Artwork File]', fileField.files[0].name);
    formData.append('properties[Holder Type]', formState.holderType);
    formData.append('properties[Size]', formState.size);
    formData.append('properties[Finish]', formState.finish);
  }
  
  fetch('/cart/add.js', {
    method: 'POST',
    body: formData
  })
  .then(response => {
    if (response.ok) {
      window.location.href = '/cart';
    } else {
      alert('Error adding to cart. Please try again.');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Error adding to cart. Please try again.');
  });
}

function findVariantByPrice(price) {
  // Search through product variants for the matching price
  // This is a simplified implementation - adjust based on your product structure
  const variantPrice = parseFloat(price);
  
  // In a real implementation, you'd iterate through the product's variants
  // and find the one with the matching price
  
  // For now, return a placeholder - this should be replaced with actual variant lookup
  if (product && product.variants) {
    for (let variant of product.variants) {
      if (Math.abs(variant.price / 100 - variantPrice) < 0.01) {
        return variant.id;
      }
    }
  }
  
  return null;
}

setupEventListeners();
showStep(1);
