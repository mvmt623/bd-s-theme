{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Top Loader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), Wide size,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 30px;
    display: none;
  }

  .sticky-summary.visible {
    display: block;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-label {
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-step {
    display: none;
    animation: slideIn 0.3s ease-out;
  }

  .form-step.active {
    display: block;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .step-heading {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--bd-white);
  }

  .step-subtext {
    font-size: 14px;
    color: var(--bd-light);
    margin-bottom: 30px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
  }

  .card-grid.three-cols {
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
    .card-grid.three-cols {
      grid-template-columns: 1fr;
    }
  }

  .option-card {
    border: 2px solid var(--bd-gray);
    border-radius: 8px;
    padding: 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background-color: var(--bd-dark);
    position: relative;
  }

  .option-card:hover {
    border-color: var(--bd-red);
    transform: translateY(-2px);
  }

  .option-card.selected {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
    box-shadow: 0 0 20px rgba(204, 0, 0, 0.3);
  }

  .option-card-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--bd-white);
  }

  .option-card-subtext {
    font-size: 13px;
    color: var(--bd-light);
  }

  .option-card-price {
    font-size: 12px;
    color: var(--bd-gold);
    font-weight: 600;
    margin-top: 8px;
  }

  .badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: var(--bd-gold);
    color: var(--bd-black);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* Finish swatches */
  .finish-swatch {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    margin: 0 auto 12px;
    border: 3px solid rgba(255,255,255,0.15);
  }
  .finish-swatch.regular { background: linear-gradient(135deg, #e8e8e8, #c0c0c0); }
  .finish-swatch.holo    { background: linear-gradient(135deg, #ff00cc, #3333ff, #00ffcc, #ffcc00); }
  .finish-swatch.cracked { background: linear-gradient(135deg, #00ccff, #004488, #0088cc); }

  /* Quantity table */
  .quantity-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
    background-color: var(--bd-dark);
    border-radius: 8px;
    overflow: hidden;
  }

  .quantity-table thead {
    background-color: var(--bd-gray);
  }

  .quantity-table th {
    padding: 12px;
    text-align: left;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
  }

  .quantity-table td {
    padding: 14px 12px;
    border-top: 1px solid var(--bd-gray);
  }

  .quantity-row {
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .quantity-row:hover {
    background-color: rgba(204, 0, 0, 0.1);
  }

  .quantity-row.selected {
    background-color: rgba(204, 0, 0, 0.2);
    border-left: 4px solid var(--bd-red);
  }

  .quantity-table td:first-child {
    padding-left: 16px;
  }

  .quantity-badge {
    background-color: var(--bd-gold);
    color: var(--bd-black);
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    margin-left: 8px;
    display: inline-block;
  }

  .quantity-price {
    font-weight: 700;
    color: var(--bd-gold);
    font-size: 16px;
  }

  .quantity-note {
    background-color: var(--bd-dark);
    border-left: 3px solid var(--bd-gold);
    padding: 12px 16px;
    border-radius: 4px;
    font-size: 13px;
    color: var(--bd-light);
    margin-bottom: 30px;
  }

  /* Form fields */
  .form-field {
    margin-bottom: 24px;
  }

  .form-field label {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
    font-size: 14px;
    color: var(--bd-white);
  }

  .form-field input[type="text"],
  .form-field textarea {
    width: 100%;
    padding: 12px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    color: var(--bd-white);
    font-family: inherit;
    font-size: 14px;
    transition: border-color 0.3s ease;
  }

  .form-field input[type="text"]:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--bd-red);
    box-shadow: 0 0 8px rgba(204, 0, 0, 0.3);
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--bd-gray);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .help-text {
    font-size: 12px;
    color: var(--bd-light);
    margin-top: 6px;
  }

  /* ── FILE UPLOAD ── */
  .artwork-upload-zone {
    border: 2px dashed var(--bd-gray);
    border-radius: 10px;
    padding: 2rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.25s, background-color 0.25s;
    background-color: var(--bd-dark);
    position: relative;
    margin-bottom: 16px;
  }
  .artwork-upload-zone:hover,
  .artwork-upload-zone.drag-over {
    border-color: var(--bd-red);
    background-color: rgba(204,0,0,0.05);
  }
  .artwork-upload-zone.has-file {
    border-color: var(--bd-gold);
    background-color: rgba(212,160,23,0.05);
  }
  .upload-icon-area {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    pointer-events: none;
  }
  .upload-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--bd-white);
    margin: 0 0 4px;
    pointer-events: none;
  }
  .upload-subtitle {
    font-size: 0.85rem;
    color: #aaa;
    margin: 0 0 8px;
    pointer-events: none;
  }
  .upload-formats {
    font-size: 0.75rem;
    color: #666;
    margin: 0;
    pointer-events: none;
  }
  .upload-file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    font-size: 0;
  }
  .upload-preview {
    display: none;
    margin-top: 12px;
    padding: 10px 14px;
    background: #222;
    border-radius: 6px;
    font-size: 13px;
    color: var(--bd-gold);
    font-weight: 600;
    align-items: center;
    gap: 10px;
  }
  .upload-preview.visible { display: flex; }
  .upload-preview-img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid #444;
  }
  .upload-preview-info { flex: 1; text-align: left; }
  .upload-preview-name { color: var(--bd-white); font-size: 13px; font-weight: 600; }
  .upload-preview-size { color: #888; font-size: 11px; margin-top: 2px; }
  .upload-remove-btn {
    background: none;
    border: none;
    color: #cc4444;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    padding: 0 4px;
  }
  .upload-or {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0;
    color: #555;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .upload-or::before,
  .upload-or::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #333;
  }
  .artwork-link-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .upload-success-badge {
    display: none;
    background: rgba(212,160,23,0.15);
    border: 1px solid var(--bd-gold);
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    color: var(--bd-gold);
    margin-bottom: 16px;
    align-items: center;
    gap: 8px;
  }
  .upload-success-badge.visible { display: flex; }

  /* Toggle / secondary logo */
  .toggle-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 28px;
  }

  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--bd-gray);
    transition: 0.3s;
    border-radius: 28px;
  }

  .toggle-slider:before {
    position: absolute;
    content: "";
    height: 22px;
    width: 22px;
    left: 3px;
    bottom: 3px;
    background-color: var(--bd-white);
    transition: 0.3s;
    border-radius: 50%;
  }

  input:checked + .toggle-slider {
    background-color: var(--bd-red);
  }

  input:checked + .toggle-slider:before {
    transform: translateX(22px);
  }

  .toggle-label {
    font-weight: 600;
    font-size: 14px;
    color: var(--bd-white);
  }

  .secondary-field {
    display: none;
    margin-left: 62px;
    padding-top: 12px;
    padding-bottom: 12px;
  }

  .secondary-field.visible {
    display: block;
  }

  /* Buttons */
  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 40px;
  }

  .btn {
    flex: 1;
    padding: 14px 24px;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .btn-primary {
    background-color: var(--bd-red);
    color: var(--bd-white);
  }

  .btn-primary:hover:not(:disabled) {
    background-color: var(--bd-red-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(204, 0, 0, 0.4);
  }

  .btn-primary:disabled {
    background-color: var(--bd-gray);
    cursor: not-allowed;
    opacity: 0.5;
  }

  .btn-secondary {
    background-color: var(--bd-dark);
    color: var(--bd-white);
    border: 1px solid var(--bd-gray);
  }

  .btn-secondary:hover {
    border-color: var(--bd-red);
    color: var(--bd-red);
  }

  .btn-back {
    flex: 0 0 auto;
    width: 120px;
  }

  .error-message {
    color: var(--bd-red);
    font-size: 13px;
    margin-top: 6px;
    display: none;
  }

  .error-message.visible {
    display: block;
  }

  .loading-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--bd-gold);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 8px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 640px) {
    .bigdawgs-form-container {
      padding: 24px 16px;
    }

    .step-heading {
      font-size: 22px;
    }

    .btn {
      padding: 12px 16px;
      font-size: 14px;
    }

    .form-actions {
      flex-direction: column;
    }

    .btn-back {
      width: 100%;
    }

    .artwork-upload-zone {
      padding: 1.5rem 1rem;
    }
  }
</style>

<div class="bigdawgs-form-container">
  <div class="form-progress-bar">
    <div class="progress-dot active" data-step="1"></div>
    <div class="progress-dot" data-step="2"></div>
    <div class="progress-dot" data-step="3"></div>
    <div class="progress-dot" data-step="4"></div>
    <div class="progress-dot" data-step="5"></div>
  </div>

  <div class="sticky-summary" id="summary">
    <div class="summary-item">
      <span class="summary-label">Holder Type:</span>
      <span id="summary-holder-type">Not selected</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Finish:</span>
      <span id="summary-finish">Not selected</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Size:</span>
      <span id="summary-size">Not selected</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">Quantity:</span>
      <span id="summary-quantity">Not selected</span>
    </div>
    <div class="summary-item" id="summary-price-row" style="display:none;">
      <span class="summary-label">Price:</span>
      <span id="summary-price" style="color:var(--bd-gold);font-weight:700;">—</span>
    </div>
  </div>

  <form id="bigdawgs-form" action="/cart/add" method="post">
    <!-- STEP 1: Holder Type -->
    <div class="form-step active" data-step="1">
      <h2 class="step-heading">Select Holder Type</h2>
      <p class="step-subtext">What type of card holder are you protecting?</p>

      <div class="card-grid">
        <div class="option-card" data-value="One Touch" data-step="1">
          <div class="option-card-title">One Touch</div>
          <div class="option-card-subtext">For PSA/BGS slabs &amp; mag holders</div>
        </div>
        <div class="option-card" data-value="Toploader" data-step="1">
          <div class="option-card-title">Toploader</div>
          <div class="option-card-subtext">For standard card toploaders</div>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn btn-primary" id="step-1-next">Continue</button>
      </div>
    </div>

    <!-- STEP 2: Finish -->
    <div class="form-step" data-step="2">
      <h2 class="step-heading">Select Finish</h2>
      <p class="step-subtext">Choose your sticker finish preference</p>

      <div class="card-grid three-cols">
        <div class="option-card" data-value="Regular" data-step="2">
          <div class="finish-swatch regular"></div>
          <div class="option-card-title">Regular</div>
          <div class="option-card-subtext">Clean, professional matte look</div>
          <div class="option-card-price">From $6</div>
        </div>
        <div class="option-card" data-value="Holographic" data-step="2">
          <div class="finish-swatch holo"></div>
          <div class="option-card-title">Holographic</div>
          <div class="option-card-subtext">Rainbow shine, eye-catching</div>
          <div class="option-card-price">From $7</div>
        </div>
        <div class="option-card" data-value="Cracked Ice" data-step="2">
          <div class="finish-swatch cracked"></div>
          <div class="option-card-title">Cracked Ice</div>
          <div class="option-card-subtext">Unique fractured-crystal pattern</div>
          <div class="option-card-price">From $7</div>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn btn-secondary btn-back" id="step-2-back">Back</button>
        <button type="button" class="btn btn-primary" id="step-2-next">Continue</button>
      </div>
    </div>

    <!-- STEP 3: Size -->
    <div class="form-step" data-step="3">
      <h2 class="step-heading">Select Size</h2>
      <p class="step-subtext">Choose the sticker size for your holders</p>

      <div class="card-grid three-cols">
        <div class="option-card" data-value="Small (0.5&quot;)" data-step="3">
          <div class="option-card-title">Small</div>
          <div class="option-card-subtext">Fits slim holders</div>
          <div style="font-size: 11px; color: #888; margin-top: 8px;">0.5"</div>
        </div>
        <div class="option-card" data-value="Medium (0.75&quot;)" data-step="3">
          <div class="badge">POPULAR</div>
          <div class="option-card-title">Medium</div>
          <div class="option-card-subtext">Most popular size</div>
          <div style="font-size: 11px; color: #888; margin-top: 8px;">0.75"</div>
        </div>
        <div class="option-card" data-value="Wide (1.0&quot;)" data-step="3">
          <div class="option-card-title">Wide</div>
          <div class="option-card-subtext">Max coverage for thick holders</div>
          <div style="font-size: 11px; color: #888; margin-top: 8px;">1.0"</div>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn btn-secondary btn-back" id="step-3-back">Back</button>
        <button type="button" class="btn btn-primary" id="step-3-next">Continue</button>
      </div>
    </div>

    <!-- STEP 4: Quantity -->
    <div class="form-step" data-step="4">
      <h2 class="step-heading">Select Quantity</h2>
      <p class="step-subtext">Choose your order quantity — bigger tiers = more per dollar</p>

      <div class="quantity-note">💰 All prices shown are flat — no hidden fees. Select the tier that works for your collection.</div>

      <table class="quantity-table">
        <thead>
          <tr>
            <th>Quantity</th>
            <th>Price</th>
            <th>Per Sticker</th>
          </tr>
        </thead>
        <tbody id="quantity-tbody">
          <!-- Populated by JavaScript -->
        </tbody>
      </table>

      <div class="form-actions">
        <button type="button" class="btn btn-secondary btn-back" id="step-4-back">Back</button>
        <button type="button" class="btn btn-primary" id="step-4-next">Continue</button>
      </div>
    </div>

    <!-- STEP 5: Artwork & Details -->
    <div class="form-step" data-step="5">
      <h2 class="step-heading">Artwork &amp; Details</h2>
      <p class="step-subtext">Upload your artwork or paste a link — we'll confirm before printing</p>

      <!-- File Upload Zone -->
      <div class="form-field">
        <label>Artwork (Front)</label>

        <div class="artwork-upload-zone" id="artwork-upload-zone">
          <input
            type="file"
            id="artwork-file-input"
            class="upload-file-input"
            accept="image/*,.pdf,.ai,.psd,.eps"
            capture="environment"
          >
          <div class="upload-icon-area" id="upload-icon">📎</div>
          <p class="upload-title" id="upload-title-text">Upload Your Artwork</p>
          <p class="upload-subtitle" id="upload-subtitle-text">Drag &amp; drop or tap to browse files</p>
          <p class="upload-formats">JPG, PNG, GIF, PDF, AI, PSD · Any size · Mobile camera supported</p>
        </div>

        <div class="upload-preview" id="upload-preview">
          <img class="upload-preview-img" id="upload-preview-img" src="" alt="" style="display:none;">
          <div class="upload-preview-info">
            <div class="upload-preview-name" id="upload-preview-name">—</div>
            <div class="upload-preview-size" id="upload-preview-size">—</div>
          </div>
          <button type="button" class="upload-remove-btn" id="upload-remove-btn" title="Remove file">✕</button>
        </div>

        <div class="upload-success-badge" id="upload-success-badge">
          <span>✓</span>
          <span id="upload-success-text">Artwork file noted — we'll email you to collect it securely after your order.</span>
        </div>

        <div class="upload-or">or paste a link</div>

        <label class="artwork-link-label" for="artwork-link-input">Google Drive / Dropbox / iCloud link (optional if file uploaded above)</label>
        <input
          type="text"
          id="artwork-link-input"
          placeholder="https://drive.google.com/..."
        >
        <div class="help-text">High-res PNG, vector (AI/PDF), or JPG preferred. We'll confirm before printing.</div>
      </div>

      <!-- Hidden property fields -->
      <input type="hidden" id="prop-artwork-front" name="properties[Artwork]" value="">

      <div class="form-field">
        <div class="toggle-wrapper">
          <label class="toggle-switch">
            <input type="checkbox" id="secondary-toggle">
            <span class="toggle-slider"></span>
          </label>
          <label class="toggle-label" for="secondary-toggle">Add secondary logo / QR code (+$2)</label>
        </div>
      </div>

      <div class="secondary-field" id="secondary-field">
        <div class="form-field">
          <label>Secondary Artwork</label>
          <div class="artwork-upload-zone" id="secondary-upload-zone" style="padding: 1.5rem 1rem;">
            <input
              type="file"
              id="secondary-file-input"
              class="upload-file-input"
              accept="image/*,.pdf,.ai,.psd"
              capture="environment"
            >
            <div class="upload-icon-area" style="font-size:1.8rem; margin-bottom: .4rem;">📎</div>
            <p class="upload-title" style="font-size:.9rem;">Upload Secondary Artwork</p>
            <p class="upload-subtitle" style="font-size:.8rem;">Logo, QR code, or social handle</p>
          </div>
          <div class="upload-preview" id="secondary-upload-preview">
            <div class="upload-preview-info">
              <div class="upload-preview-name" id="secondary-preview-name">—</div>
            </div>
            <button type="button" class="upload-remove-btn" id="secondary-remove-btn" title="Remove file">✕</button>
          </div>
          <div class="upload-or">or paste a link</div>
          <input
            type="text"
            id="secondary-link-input"
            placeholder="https://drive.google.com/..."
          >
        </div>
      </div>

      <div class="form-field">
        <label for="order-notes">Order Notes</label>
        <textarea
          id="order-notes"
          name="properties[Order Notes]"
          placeholder="Any special instructions, colors, or details..."
        ></textarea>
      </div>

      <!-- Hidden cart fields -->
      <input type="hidden" name="id" id="variant-id" value="">
      <input type="hidden" name="quantity" id="cart-quantity" value="">
      <input type="hidden" name="properties[Holder Type]" id="prop-holder-type" value="">
      <input type="hidden" name="properties[Finish]" id="prop-finish" value="">
      <input type="hidden" name="properties[Size]" id="prop-size" value="">
      <input type="hidden" name="properties[Quantity Tier]" id="prop-quantity-tier" value="">
      <input type="hidden" name="properties[Price]" id="prop-price" value="">
      <input type="hidden" name="properties[Secondary Logo]" id="prop-secondary-logo" value="">
      <input type="hidden" name="properties[Secondary Artwork]" id="prop-secondary-artwork" value="">

      <div class="form-actions">
        <button type="button" class="btn btn-secondary btn-back" id="step-5-back">Back</button>
        <button type="submit" class="btn btn-primary" id="submit-btn">Add to Cart</button>
      </div>
    </div>
  </form>
</div>

<script>
  // ── PRICING DATA ──
  // Key format: "holderType|size|finishCategory"  (finishCategory: "regular" or "holo")
  // Each tier: { qty, price, best }
  const quantityTiers = {
    // ONE TOUCH — REGULAR
    "One Touch|Small (0.5\")|regular":   [{qty:25,price:6},{qty:50,price:10},{qty:100,price:15,best:true}],
    "One Touch|Medium (0.75\")|regular": [{qty:20,price:6},{qty:45,price:10},{qty:90,price:15,best:true}],
    "One Touch|Wide (1.0\")|regular":    [{qty:15,price:6},{qty:35,price:10},{qty:70,price:15,best:true}],
    // ONE TOUCH — HOLO / CRACKED ICE
    "One Touch|Small (0.5\")|holo":      [{qty:25,price:7},{qty:50,price:13},{qty:100,price:20,best:true}],
    "One Touch|Medium (0.75\")|holo":    [{qty:20,price:7},{qty:45,price:13},{qty:90,price:20,best:true}],
    "One Touch|Wide (1.0\")|holo":       [{qty:15,price:7},{qty:35,price:13},{qty:70,price:20,best:true}],
    // TOPLOADER — REGULAR
    "Toploader|Small (0.5\")|regular":   [{qty:30,price:6},{qty:75,price:10},{qty:150,price:15,best:true}],
    "Toploader|Medium (0.75\")|regular": [{qty:25,price:6},{qty:50,price:10},{qty:100,price:15,best:true}],
    "Toploader|Wide (1.0\")|regular":    [{qty:20,price:6},{qty:40,price:10},{qty:80,price:15,best:true}],
    // TOPLOADER — HOLO / CRACKED ICE
    "Toploader|Small (0.5\")|holo":      [{qty:30,price:7},{qty:70,price:13},{qty:150,price:20,best:true}],
    "Toploader|Medium (0.75\")|holo":    [{qty:25,price:7},{qty:50,price:13},{qty:100,price:20,best:true}],
    "Toploader|Wide (1.0\")|holo":       [{qty:20,price:7},{qty:40,price:13},{qty:80,price:20,best:true}]
  };

  function getFinishCategory(finish) {
    return (finish === 'Holographic' || finish === 'Cracked Ice') ? 'holo' : 'regular';
  }

  // ============================================================
  // TESTING MODE — flip to false to re-enable artwork validation
  const TESTING_MODE = true;
  // ============================================================

  // Form state
  const formState = {
    holderType: null,
    finish: null,
    size: null,
    quantity: null,
    price: null,
    artworkFileName: null,
    currentStep: 1,
    stepsCompleted: new Set()
  };

  // Product variants data
  const productVariants = {{ product.variants | json }};

  // Initialize
  document.addEventListener('DOMContentLoaded', function() {
    initializeFormListeners();
    initializeToggle();
    initializeFileUpload();
  });

  function initializeFormListeners() {
    document.getElementById('step-1-next').addEventListener('click', () => validateAndAdvance(1));
    document.getElementById('step-2-back').addEventListener('click', () => goToStep(1));
    document.getElementById('step-2-next').addEventListener('click', () => validateAndAdvance(2));
    document.getElementById('step-3-back').addEventListener('click', () => goToStep(2));
    document.getElementById('step-3-next').addEventListener('click', () => validateAndAdvance(3));
    document.getElementById('step-4-back').addEventListener('click', () => goToStep(3));
    document.getElementById('step-4-next').addEventListener('click', () => validateAndAdvance(4));
    document.getElementById('step-5-back').addEventListener('click', () => goToStep(4));

    document.querySelectorAll('.option-card').forEach(card => {
      card.addEventListener('click', function() {
        selectCard(this);
      });
    });

    document.getElementById('bigdawgs-form').addEventListener('submit', handleFormSubmit);
  }

  function initializeToggle() {
    const toggle = document.getElementById('secondary-toggle');
    const secondaryField = document.getElementById('secondary-field');
    toggle.addEventListener('change', function() {
      if (this.checked) {
        secondaryField.classList.add('visible');
      } else {
        secondaryField.classList.remove('visible');
      }
    });
  }

  // ── FILE UPLOAD LOGIC ──
  function initializeFileUpload() {
    setupUploadZone(
      'artwork-upload-zone',
      'artwork-file-input',
      'upload-preview',
      'upload-preview-img',
      'upload-preview-name',
      'upload-preview-size',
      'upload-remove-btn',
      'upload-success-badge',
      function(name, dataUrl) {
        formState.artworkFileName = name;
        document.getElementById('prop-artwork-front').value = name;
      },
      function() {
        formState.artworkFileName = null;
        document.getElementById('prop-artwork-front').value = '';
      }
    );

    setupUploadZone(
      'secondary-upload-zone',
      'secondary-file-input',
      'secondary-upload-preview',
      null,
      'secondary-preview-name',
      null,
      'secondary-remove-btn',
      null,
      function(name) {
        document.getElementById('prop-secondary-artwork').value = name;
      },
      function() {
        document.getElementById('prop-secondary-artwork').value = '';
      }
    );
  }

  function setupUploadZone(zoneId, inputId, previewId, previewImgId, previewNameId, previewSizeId, removeBtnId, successBadgeId, onFile, onRemove) {
    var zone = document.getElementById(zoneId);
    var input = document.getElementById(inputId);
    var preview = document.getElementById(previewId);
    var removBtn = document.getElementById(removeBtnId);
    if (!zone || !input) return;

    // Drag events
    zone.addEventListener('dragover', function(e) {
      e.preventDefault();
      zone.classList.add('drag-over');
    });
    zone.addEventListener('dragleave', function() {
      zone.classList.remove('drag-over');
    });
    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.classList.remove('drag-over');
      var files = e.dataTransfer.files;
      if (files && files[0]) handleFile(files[0]);
    });

    // Input change
    input.addEventListener('change', function() {
      if (this.files && this.files[0]) handleFile(this.files[0]);
    });

    // Remove button
    if (removBtn) {
      removBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        clearUpload();
        onRemove();
      });
    }

    function handleFile(file) {
      zone.classList.add('has-file');

      // Name
      var nameEl = document.getElementById(previewNameId);
      if (nameEl) nameEl.textContent = file.name;

      // Size
      if (previewSizeId) {
        var sizeEl = document.getElementById(previewSizeId);
        if (sizeEl) sizeEl.textContent = formatBytes(file.size);
      }

      // Image preview
      if (previewImgId && file.type.startsWith('image/')) {
        var reader = new FileReader();
        reader.onload = function(e) {
          var img = document.getElementById(previewImgId);
          if (img) { img.src = e.target.result; img.style.display = 'block'; }
          onFile(file.name, e.target.result);
        };
        reader.readAsDataURL(file);
      } else {
        onFile(file.name, null);
      }

      // Show preview
      if (preview) preview.classList.add('visible');

      // Success badge
      if (successBadgeId) {
        var badge = document.getElementById(successBadgeId);
        if (badge) {
          badge.classList.add('visible');
          var txt = badge.querySelector('#upload-success-text');
          if (txt) txt.textContent = '"' + file.name + '" selected. We\'ll email you to collect your artwork securely after your order.';
        }
      }

      // Update zone appearance
      var titleEl = document.getElementById('upload-title-text');
      var subEl = document.getElementById('upload-subtitle-text');
      if (titleEl) titleEl.textContent = '✓ File ready';
      if (subEl) subEl.textContent = file.name;
    }

    function clearUpload() {
      zone.classList.remove('has-file');
      if (preview) preview.classList.remove('visible');
      if (previewImgId) {
        var img = document.getElementById(previewImgId);
        if (img) { img.src = ''; img.style.display = 'none'; }
      }
      var nameEl = document.getElementById(previewNameId);
      if (nameEl) nameEl.textContent = '—';
      if (previewSizeId) {
        var sizeEl = document.getElementById(previewSizeId);
        if (sizeEl) sizeEl.textContent = '—';
      }
      if (successBadgeId) {
        var badge = document.getElementById(successBadgeId);
        if (badge) badge.classList.remove('visible');
      }
      input.value = '';
      var titleEl = document.getElementById('upload-title-text');
      var subEl = document.getElementById('upload-subtitle-text');
      if (titleEl) titleEl.textContent = 'Upload Your Artwork';
      if (subEl) subEl.textContent = 'Drag & drop or tap to browse files';
    }
  }

  function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  // ── CARD SELECTION ──
  function selectCard(card) {
    var step = card.getAttribute('data-step');
    var value = card.getAttribute('data-value');

    document.querySelectorAll('.option-card[data-step="' + step + '"]').forEach(function(c) {
      c.classList.remove('selected');
    });
    card.classList.add('selected');

    if (step === '1') {
      formState.holderType = value;
      updateSummary('holderType', value);
    } else if (step === '2') {
      formState.finish = value;
      updateSummary('finish', value);
    } else if (step === '3') {
      formState.size = value;
      updateSummary('size', value);
    }
  }

  // ── STEP NAVIGATION ──
  function validateAndAdvance(currentStep) {
    if (currentStep === 1 && !formState.holderType) {
      showError('Please select a holder type');
      return;
    }
    if (currentStep === 2 && !formState.finish) {
      showError('Please select a finish');
      return;
    }
    if (currentStep === 3 && !formState.size) {
      showError('Please select a size');
      return;
    }
    if (currentStep === 4 && !formState.quantity) {
      showError('Please select a quantity');
      return;
    }
    goToStep(currentStep + 1);
  }

  function goToStep(step) {
    document.querySelectorAll('.form-step').forEach(function(el) {
      el.classList.remove('active');
    });
    document.querySelector('.form-step[data-step="' + step + '"]').classList.add('active');

    document.querySelectorAll('.progress-dot').forEach(function(dot, idx) {
      var dotStep = idx + 1;
      dot.classList.remove('active', 'completed');
      if (dotStep === step) {
        dot.classList.add('active');
      } else if (dotStep < step) {
        dot.classList.add('completed');
      }
    });

    if (step > 1) {
      document.getElementById('summary').classList.add('visible');
    }

    if (step === 4) {
      populateQuantityTable();
    }

    formState.currentStep = step;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── QUANTITY TABLE ──
  function populateQuantityTable() {
    var finishCat = getFinishCategory(formState.finish);
    var key = formState.holderType + '|' + formState.size + '|' + finishCat;
    var tiers = quantityTiers[key];
    var tbody = document.getElementById('quantity-tbody');
    tbody.innerHTML = '';

    if (!tiers || !tiers.length) {
      tbody.innerHTML = '<tr><td colspan="3" style="color:#888;text-align:center;padding:20px;">Contact us for pricing on this combination</td></tr>';
      return;
    }

    tiers.forEach(function(tier) {
      var row = document.createElement('tr');
      row.className = 'quantity-row';
      if (formState.quantity === tier.qty) row.classList.add('selected');

      var qtyCell = document.createElement('td');
      qtyCell.innerHTML = tier.qty + ' stickers';
      if (tier.best) {
        qtyCell.innerHTML += ' <span class="quantity-badge">Best Value</span>';
      }

      var priceCell = document.createElement('td');
      priceCell.innerHTML = '<span class="quantity-price">$' + tier.price + '</span>';

      var perCell = document.createElement('td');
      var perSticker = (tier.price / tier.qty);
      perCell.textContent = perSticker < 0.01 ? '<$0.01' : '$' + perSticker.toFixed(2);
      perCell.style.color = '#888';
      perCell.style.fontSize = '13px';

      row.appendChild(qtyCell);
      row.appendChild(priceCell);
      row.appendChild(perCell);

      row.addEventListener('click', function(e) {
        selectQuantity(tier.qty, tier.price, e);
      });

      tbody.appendChild(row);
    });
  }

  function selectQuantity(qty, price, event) {
    formState.quantity = qty;
    formState.price = price;
    updateSummary('quantity', qty + ' stickers');

    // Show price in summary
    document.getElementById('summary-price-row').style.display = 'flex';
    document.getElementById('summary-price').textContent = '$' + price;

    document.querySelectorAll('.quantity-row').forEach(function(row) {
      row.classList.remove('selected');
    });
    event.currentTarget.classList.add('selected');
  }

  function updateSummary(field, value) {
    var summaryMap = {
      'holderType': 'summary-holder-type',
      'finish': 'summary-finish',
      'size': 'summary-size',
      'quantity': 'summary-quantity'
    };
    if (summaryMap[field]) {
      document.getElementById(summaryMap[field]).textContent = value;
    }
  }

  function showError(message) {
    alert(message);
  }

  // ── FORM SUBMIT ──
  function handleFormSubmit(e) {
    e.preventDefault();

    if (!formState.holderType || !formState.finish || !formState.size || !formState.quantity) {
      showError('Please complete all steps before submitting');
      return;
    }

    // Check artwork: either file or link required
    var artworkFile = formState.artworkFileName;
    var artworkLink = document.getElementById('artwork-link-input').value.trim();

    if (!TESTING_MODE && !artworkFile && !artworkLink) {
      showError('Please upload your artwork file or paste a link to continue');
      return;
    }

    // Set artwork property
    var artworkValue = artworkFile
      ? 'File: ' + artworkFile + ' (will be emailed)'
      : artworkLink;
    document.getElementById('prop-artwork-front').value = artworkValue;

    // Secondary logo
    var secondaryToggle = document.getElementById('secondary-toggle').checked;
    if (secondaryToggle) {
      var secondaryFile = document.getElementById('prop-secondary-artwork').value;
      var secondaryLink = document.getElementById('secondary-link-input').value.trim();
      var secondaryValue = secondaryFile
        ? 'File: ' + secondaryFile + ' (will be emailed)'
        : secondaryLink;
      document.getElementById('prop-secondary-artwork').value = secondaryValue;
      document.getElementById('prop-secondary-logo').value = 'Yes';
    } else {
      document.getElementById('prop-secondary-logo').value = 'No';
    }

    // Populate hidden fields
    document.getElementById('prop-holder-type').value = formState.holderType;
    document.getElementById('prop-finish').value = formState.finish;
    document.getElementById('prop-size').value = formState.size;
    document.getElementById('prop-quantity-tier').value = formState.quantity + ' stickers';
    document.getElementById('prop-price').value = '$' + formState.price;
    document.getElementById('cart-quantity').value = '1';

    var variant = productVariants[0];
    if (variant) {
      document.getElementById('variant-id').value = variant.id;
    }

    var submitBtn = document.getElementById('submit-btn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="loading-spinner"></span>Adding to Cart...';

    setTimeout(function() {
      e.target.submit();
    }, 400);
  }
</script>

