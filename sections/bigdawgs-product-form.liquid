{% comment %}
  BIG DAWGS - Custom Card Stickers Product Form
  A multi-step form for configuring and ordering custom card stickers
  for One Touch and Toploader card holders.
  v2: Real pricing, renamed finishes (Regular/Holo/Cracked Ice), sizes Small/Medium/Large,
      drag-and-drop file upload with mobile camera support
{% endcomment %}

{%- liquid
  assign product = all_products['custom-card-stickers']
  if product == empty
    assign product = collection.products.first
  endif
-%}

<style>
  :root {
    --bd-red: #CC0000;
    --bd-red-dark: #990000;
    --bd-gold: #D4A017;
    --bd-black: #111111;
    --bd-dark: #1A1A1A;
    --bd-gray: #333333;
    --bd-light: #F5F5F5;
    --bd-white: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  .bigdawgs-form-container {
    background-color: var(--bd-black);
    color: var(--bd-white);
    padding: 40px 20px;
    border-radius: 8px;
    max-width: 800px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .form-progress-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    justify-content: space-between;
  }

  .progress-dot {
    flex: 1;
    height: 4px;
    background-color: var(--bd-gray);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .progress-dot.active {
    background-color: var(--bd-red);
  }

  .progress-dot.completed {
    background-color: var(--bd-gold);
  }

  .sticky-summary {
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 30px;
    display: none;
  }

  .sticky-summary.visible {
    display: block;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .summary-label {
    font-weight: 600;
    color: var(--bd-white);
  }

  .form-step {
    display: none;
  }

  .form-step.active {
    display: block;
  }

  .form-group {
    margin-bottom: 30px;
  }

  .form-group label {
    display: block;
    margin-bottom: 10px;
    font-weight: 600;
  }

  .button-group {
    display: flex;
    gap: 10px;
  }

  .form-button {
    flex: 1;
    padding: 12px 20px;
    background-color: var(--bd-red);
    color: white;
    border: 2px solid var(--bd-red);
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .form-button:hover {
    background-color: var(--bd-red-dark);
  }

  .form-button.secondary {
    background-color: transparent;
    color: var(--bd-red);
  }

  .form-button.secondary:hover {
    background-color: rgba(204, 0, 0, 0.1);
  }

  .form-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-button.gold {
    background-color: var(--bd-gold);
    border-color: var(--bd-gold);
    color: var(--bd-black);
  }

  .form-button.gold:hover {
    background-color: #C69410;
  }

  .file-upload-area {
    border: 2px dashed var(--bd-gray);
    border-radius: 8px;
    padding: 40px 20px;
    text-align: center;
    background-color: var(--bd-dark);
    cursor: pointer;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .file-upload-area:hover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.05);
  }

  .file-upload-area.dragover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.1);
  }

  .file-upload-area p {
    margin: 0;
    font-size: 14px;
    color: var(--bd-light);
  }

  .file-upload-area p:first-child {
    margin-bottom: 5px;
    font-weight: 600;
  }

  .upload-icon {
    font-size: 32px;
    margin-bottom: 10px;
  }

  .file-preview {
    margin-top: 20px;
    padding: 15px;
    background-color: var(--bd-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .file-preview-name {
    word-break: break-all;
    flex: 1;
  }

  .file-preview-remove {
    margin-left: 10px;
    cursor: pointer;
    color: var(--bd-red);
    font-weight: 600;
  }

  .file-input {
    display: none;
  }

  .form-step h2 {
    margin-top: 0;
    margin-bottom: 20px;
    font-size: 20px;
    color: var(--bd-white);
  }

  .form-step h3 {
    margin-top: 15px;
    margin-bottom: 15px;
    font-size: 16px;
    color: var(--bd-white);
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
  }

  .option-button {
    padding: 15px;
    background-color: var(--bd-dark);
    border: 2px solid var(--bd-gray);
    border-radius: 6px;
    color: var(--bd-light);
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .option-button:hover {
    border-color: var(--bd-red);
    background-color: rgba(204, 0, 0, 0.05);
  }

  .option-button.selected {
    background-color: var(--bd-red);
    border-color: var(--bd-red);
    color: var(--bd-white);
  }

  input[type="number"],
  input[type="text"],
  input[type="email"],
  textarea {
    width: 100%;
    padding: 12px;
    background-color: var(--bd-dark);
    border: 1px solid var(--bd-gray);
    border-radius: 4px;
    color: var(--bd-white);
    font-family: inherit;
    box-sizing: border-box;
  }

  input[type="number"]::placeholder,
  input[type="text"]::placeholder,
  input[type="email"]::placeholder,
  textarea::placeholder {
    color: #999;
  }

  input[type="number"]:focus,
  input[type="text"]:focus,
  input[type="email"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--bd-red);
    box-shadow: 0 0 0 2px rgba(204, 0, 0, 0.1);
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  .help-text {
    font-size: 12px;
    color: #999;
    margin-top: 5px;
  }

  .success-message {
    background-color: #2a7d3a;
    border: 1px solid #1f5a2a;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
    color: #90ee90;
  }

  .error-message {
    background-color: #7d2a2a;
    border: 1px solid #5a1f1f;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
    color: #ff6b6b;
  }

  .step-number {
    display: inline-block;
    background-color: var(--bd-red);
    color: white;
    width: 28px;
    height: 28px;
    line-height: 28px;
    text-align: center;
    border-radius: 50%;
    font-weight: bold;
    margin-right: 10px;
  }

  .radio-label {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
    cursor: pointer;
    font-size: 14px;
  }

  .radio-label input[type="radio"] {
    margin-right: 10px;
    cursor: pointer;
  }

  .quantity-input {
    width: 100px;
    margin-bottom: 10px;
  }

  .price-breakdown {
    background-color: var(--bd-dark);
    padding: 15px;
    border-radius: 6px;
    margin-top: 20px;
    border-left: 4px solid var(--bd-gold);
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 14px;
  }

  .price-row.total {
    border-top: 1px solid var(--bd-gray);
    padding-top: 12px;
    margin-top: 12px;
    font-weight: bold;
    color: var(--bd-gold);
    font-size: 16px;
  }

  .navigation-buttons {
    display: flex;
    gap: 10px;
    margin-top: 30px;
  }

  .nav-button {
    flex: 1;
  }
</style>

<div class="bigdawgs-form-container">
  <div class="form-progress-bar">
    <div class="progress-dot completed" id="progress-0"></div>
    <div class="progress-dot" id="progress-1"></div>
    <div class="progress-dot" id="progress-2"></div>
    <div class="progress-dot" id="progress-3"></div>
    <div class="progress-dot" id="progress-4"></div>
  </div>

  <form id="bigdawgs-form" method="POST" action="/cart/add">
    <!-- STEP 0: Holder Selection -->
    <div class="form-step active" id="step-0">
      <h2><span class="step-number">1</span>Select Holder Type</h2>
      <p>Which holder would you like sleeves for?</p>
      <div class="button-group">
        <button type="button" class="form-button secondary option-button" data-step="0" data-value="ontouch">
          One Touch Holder
        </button>
        <button type="button" class="form-button secondary option-button" data-step="0" data-value="toploader">
          Top Loader
        </button>
      </div>
      <div class="navigation-buttons">
        <button type="button" class="form-button gold nav-button" onclick="nextStep(1)">Next</button>
      </div>
    </div>

    <!-- STEP 1: Finish Selection -->
    <div class="form-step" id="step-1">
      <h2><span class="step-number">2</span>Select Finish</h2>
      <p>Choose your preferred finish:</p>
      <div class="option-grid">
        <button type="button" class="form-button secondary option-button" data-step="1" data-value="regular">
          Regular
        </button>
        <button type="button" class="form-button secondary option-button" data-step="1" data-value="holo">
          Holo
        </button>
        <button type="button" class="form-button secondary option-button" data-step="1" data-value="cracked-ice">
          Cracked Ice
        </button>
      </div>
      <div class="navigation-buttons">
        <button type="button" class="form-button secondary nav-button" onclick="previousStep(0)">Back</button>
        <button type="button" class="form-button gold nav-button" onclick="nextStep(2)">Next</button>
      </div>
    </div>

    <!-- STEP 2: Size Selection -->
    <div class="form-step" id="step-2">
      <h2><span class="step-number">3</span>Select Size</h2>
      <p>Choose the size of your custom stickers:</p>
      <div class="option-grid">
        <button type="button" class="form-button secondary option-button" data-step="2" data-value="small">
          Small
        </button>
        <button type="button" class="form-button secondary option-button" data-step="2" data-value="medium">
          Medium
        </button>
        <button type="button" class="form-button secondary option-button" data-step="2" data-value="large">
          Large
        </button>
      </div>
      <div class="navigation-buttons">
        <button type="button" class="form-button secondary nav-button" onclick="previousStep(1)">Back</button>
        <button type="button" class="form-button gold nav-button" onclick="nextStep(3)">Next</button>
      </div>
    </div>

    <!-- STEP 3: File Upload -->
    <div class="form-step" id="step-3">
      <h2><span class="step-number">4</span>Upload Design</h2>
      <p>Upload your custom sticker design (PNG, JPG, or PDF):</p>
      <div class="file-upload-area" id="file-upload-area" onclick="document.getElementById('file-input').click()">
        <div class="upload-icon">📎</div>
        <p>Drag & drop your file here</p>
        <p>or click to select</p>
      </div>
      <input type="file" id="file-input" class="file-input" accept="image/png,image/jpeg,application/pdf">
      <div id="file-preview" class="file-preview" style="display: none;">
        <span class="file-preview-name" id="file-name"></span>
        <span class="file-preview-remove" onclick="removeFile()">Remove</span>
      </div>
      <div class="navigation-buttons">
        <button type="button" class="form-button secondary nav-button" onclick="previousStep(2)">Back</button>
        <button type="button" class="form-button gold nav-button" onclick="nextStep(4)">Next</button>
      </div>
    </div>

    <!-- STEP 4: Review & Submit -->
    <div class="form-step" id="step-4">
      <h2><span class="step-number">5</span>Review & Order</h2>
      <div class="sticky-summary visible">
        <div class="summary-item">
          <span class="summary-label">Holder Type:</span>
          <span id="summary-holder">-</span>
        </div>
        <div class="summary-item">
          <span class="summary-label">Finish:</span>
          <span id="summary-finish">-</span>
        </div>
        <div class="summary-item">
          <span class="summary-label">Size:</span>
          <span id="summary-size">-</span>
        </div>
        <div class="summary-item">
          <span class="summary-label">Design File:</span>
          <span id="summary-file">-</span>
        </div>
      </div>

      <div class="form-group">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" min="1" value="1" class="quantity-input">
      </div>

      <div class="price-breakdown">
        <div class="price-row">
          <span>Unit Price:</span>
          <span id="unit-price">$0.00</span>
        </div>
        <div class="price-row">
          <span>Quantity:</span>
          <span id="price-quantity">1</span>
        </div>
        <div class="price-row total">
          <span>Total:</span>
          <span id="total-price">$0.00</span>
        </div>
      </div>

      <div class="navigation-buttons">
        <button type="button" class="form-button secondary nav-button" onclick="previousStep(3)">Back</button>
        <button type="submit" class="form-button gold nav-button">Add to Cart</button>
      </div>
    </div>
  </form>
</div>

<script>
  const selectionData = {
    holder: null,
    finish: null,
    size: null,
    file: null,
    quantity: 1
  };

  const pricing = {
    ontouch: { regular: 5.99, holo: 7.99, 'cracked-ice': 7.99 },
    toploader: { regular: 4.99, holo: 6.99, 'cracked-ice': 6.99 }
  };

  function selectOption(element, step) {
    const siblings = element.parentElement.querySelectorAll('.option-button');
    siblings.forEach(btn => btn.classList.remove('selected'));
    element.classList.add('selected');

    const value = element.getAttribute('data-value');
    const stepKey = ['holder', 'finish', 'size'][step];
    selectionData[stepKey] = value;

    updatePricing();
  }

  document.querySelectorAll('.option-button').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const step = this.getAttribute('data-step');
      selectOption(this, parseInt(step));
    });
  });

  function nextStep(step) {
    const requiredSteps = ['holder', 'finish', 'size', 'file'];
    const required = requiredSteps[step - 1];

    if (required && !selectionData[required]) {
      alert('Please select an option to continue');
      return;
    }

    document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
    document.getElementById('step-' + step).classList.add('active');

    document.querySelectorAll('.progress-dot').forEach((dot, i) => {
      dot.classList.remove('active', 'completed');
      if (i < step) dot.classList.add('completed');
      if (i === step) dot.classList.add('active');
    });

    updateSummary();
  }

  function previousStep(step) {
    document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
    document.getElementById('step-' + step).classList.add('active');

    document.querySelectorAll('.progress-dot').forEach((dot, i) => {
      dot.classList.remove('active', 'completed');
      if (i < step) dot.classList.add('completed');
      if (i === step) dot.classList.add('active');
    });
  }

  function updateSummary() {
    document.getElementById('summary-holder').textContent = selectionData.holder === 'ontouch' ? 'One Touch' : 'Top Loader';
    document.getElementById('summary-finish').textContent = selectionData.finish ? selectionData.finish.charAt(0).toUpperCase() + selectionData.finish.slice(1) : '-';
    document.getElementById('summary-size').textContent = selectionData.size ? selectionData.size.charAt(0).toUpperCase() + selectionData.size.slice(1) : '-';
    document.getElementById('summary-file').textContent = selectionData.file ? selectionData.file.name : '-';
  }

  document.getElementById('file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      selectionData.file = file;
      document.getElementById('file-name').textContent = file.name;
      document.getElementById('file-preview').style.display = 'flex';
    }
  });

  document.getElementById('file-upload-area').addEventListener('dragover', function(e) {
    e.preventDefault();
    this.classList.add('dragover');
  });

  document.getElementById('file-upload-area').addEventListener('dragleave', function() {
    this.classList.remove('dragover');
  });

  document.getElementById('file-upload-area').addEventListener('drop', function(e) {
    e.preventDefault();
    this.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file && ['image/png', 'image/jpeg', 'application/pdf'].includes(file.type)) {
      selectionData.file = file;
      document.getElementById('file-name').textContent = file.name;
      document.getElementById('file-preview').style.display = 'flex';
      document.getElementById('file-input').files = e.dataTransfer.files;
    }
  });

  function removeFile() {
    selectionData.file = null;
    document.getElementById('file-input').value = '';
    document.getElementById('file-preview').style.display = 'none';
  }

  function updatePricing() {
    if (selectionData.holder && selectionData.finish) {
      const price = pricing[selectionData.holder][selectionData.finish];
      document.getElementById('unit-price').textContent = '$' + price.toFixed(2);
      updateTotalPrice();
    }
  }

  function updateTotalPrice() {
    const quantity = parseInt(document.getElementById('quantity').value) || 1;
    selectionData.quantity = quantity;

    if (selectionData.holder && selectionData.finish) {
      const unitPrice = pricing[selectionData.holder][selectionData.finish];
      const total = (unitPrice * quantity).toFixed(2);
      document.getElementById('total-price').textContent = '$' + total;
      document.getElementById('price-quantity').textContent = quantity;
    }
  }

  document.getElementById('quantity').addEventListener('change', updateTotalPrice);
  document.getElementById('quantity').addEventListener('input', updateTotalPrice);

  document.getElementById('bigdawgs-form').addEventListener('submit', function(e) {
    e.preventDefault();

    const formData = new FormData();
    formData.append('id', window.BIGDAWGS_PRODUCT_ID || '{{ product.id }}');
    formData.append('quantity', selectionData.quantity);

    const properties = {
      'Holder Type': selectionData.holder === 'ontouch' ? 'One Touch' : 'Top Loader',
      'Finish': selectionData.finish.charAt(0).toUpperCase() + selectionData.finish.slice(1),
      'Size': selectionData.size.charAt(0).toUpperCase() + selectionData.size.slice(1)
    };

    for (const [key, value] of Object.entries(properties)) {
      formData.append(`properties[${key}]`, value);
    }

    fetch('/cart/add.js', {
      method: 'POST',
      body: formData
    })
    .then(response => response.json())
    .then(() => {
      window.location.href = '/cart';
    })
    .catch(error => console.error('Error:', error));
  });
</script>

{% schema %}
{
  "name": "BIG DAWGS Product Form",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Custom Card Stickers Product",
      "default": "custom-card-stickers"
    }
  ]
}
{% endschema %}